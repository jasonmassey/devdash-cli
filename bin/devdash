#!/usr/bin/env bash
# devdash — Dev-Dash CLI
# Thin wrapper around the dev-dash API for task tracking.
# Usage: devdash <command> [args]

set -euo pipefail

# Clean exit on Ctrl+C — suppress bash noise from errexit + pipefail
trap 'printf "\n"; exit 130' INT

DD_VERSION="0.2.0"
DD_CONFIG_DIR="${DD_CONFIG_DIR:-${HOME}/.config/dev-dash}"
DD_TOKEN_FILE="${DD_TOKEN_FILE:-${DD_CONFIG_DIR}/token}"
DD_PROJECT_FILE=".devdash"

# Exit codes: 0=success, 1=user error, 2=API error, 3=config error
DD_EXIT_USER=1
DD_EXIT_API=2
DD_EXIT_CONFIG=3

# ── Helpers ──────────────────────────────────────────────────────

dd_close_gate() {
  local gate=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    gate=$(jq -r '.close_gate // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  echo "${gate:-push}"
}

dd_frontend_url() {
  local url=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    url=$(jq -r '.frontend_url // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  echo "${url:-https://dev-dash-blue.vercel.app}"
}

dd_api_url() {
  local url=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    url=$(jq -r '.api_url // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  url="${url:-${DD_API_URL:-https://dev-dash-server-production.up.railway.app}}"

  # Enforce HTTPS (allow http only for localhost/127.0.0.1 dev)
  if [[ "$url" == http://* ]] && [[ "$url" != http://localhost* ]] && [[ "$url" != http://127.0.0.1* ]]; then
    echo "Warning: API URL uses insecure HTTP: $url" >&2
    echo "Set a https:// URL or use http://localhost for local dev." >&2
  fi
  echo "$url"
}

# Convert --since value (2w, 3d, 1h, YYYY-MM-DD) to ISO datetime string
dd_parse_since() {
  local val="$1"
  # Absolute date: YYYY-MM-DD
  if [[ "$val" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "${val}T00:00:00.000Z"
    return
  fi
  # Relative duration: Nh, Nd, Nw
  local num="${val%[hdw]}"
  local unit="${val: -1}"
  if ! [[ "$num" =~ ^[0-9]+$ ]]; then
    echo "Invalid --since value: $val (use Nh, Nd, Nw, or YYYY-MM-DD)" >&2
    return 1
  fi
  local seconds=0
  case "$unit" in
    h) seconds=$((num * 3600)) ;;
    d) seconds=$((num * 86400)) ;;
    w) seconds=$((num * 604800)) ;;
    *) echo "Invalid --since unit: $unit (use h, d, or w)" >&2; return 1 ;;
  esac
  # macOS date -v vs GNU date --date
  if date -v-1d +%s >/dev/null 2>&1; then
    date -u -v-${seconds}S +"%Y-%m-%dT%H:%M:%S.000Z"
  else
    date -u -d "@$(($(date +%s) - seconds))" +"%Y-%m-%dT%H:%M:%S.000Z"
  fi
}

dd_resolve_project_id() {
  local raw="$1"
  # Full UUID — use directly
  if [[ ${#raw} -eq 36 && "$raw" == *-*-*-*-* ]]; then
    echo "$raw"
    return
  fi
  # Prefix — resolve against project list
  local projects
  projects=$(dd_api GET "/projects" 2>/dev/null) || { echo "$raw"; return; }
  local matches
  matches=$(echo "$projects" | jq -r --arg r "$raw" '[.[] | select(.id | startswith($r))] | .[].id')
  if [ -z "$matches" ]; then
    echo "No project found matching prefix: $raw" >&2
    exit "$DD_EXIT_USER"
  fi
  local count
  count=$(echo "$matches" | wc -l | tr -d ' ')
  if [ "$count" -gt 1 ]; then
    echo "Ambiguous project prefix '$raw' matches $count projects:" >&2
    echo "$matches" | head -5 >&2
    exit "$DD_EXIT_USER"
  fi
  echo "$matches"
}

# Resolve a token ID prefix to a full UUID
dd_resolve_token_id() {
  local token_id="$1"
  # Full UUID — use directly
  if [[ ${#token_id} -eq 36 && "$token_id" == *-*-*-*-* ]]; then
    echo "$token_id"
    return
  fi
  # Short prefix — fetch all tokens and match
  local tokens
  tokens=$(dd_api GET "/auth/tokens")
  local matches
  matches=$(echo "$tokens" | dd_jq -r --arg t "$token_id" '[.[] | select(.id | startswith($t))] | .[].id')
  if [ -z "$matches" ]; then
    echo "No token found matching prefix: $token_id" >&2
    return 1
  fi
  local count
  count=$(echo "$matches" | wc -l | tr -d ' ')
  if [ "$count" -gt 1 ]; then
    echo "Ambiguous token prefix '$token_id' matches $count tokens:" >&2
    echo "$matches" | head -5 >&2
    return 1
  fi
  echo "$matches"
}

dd_project_id() {
  # Explicit env var overrides .devdash file (allows cross-project commands)
  if [ -n "${DD_PROJECT_ID:-}" ]; then
    dd_resolve_project_id "$DD_PROJECT_ID"
    return
  fi
  if [ -f "$DD_PROJECT_FILE" ]; then
    local pid
    pid=$(jq -r '.project_id // empty' "$DD_PROJECT_FILE" 2>/dev/null)
    if [ -n "$pid" ]; then
      echo "$pid"
      return
    fi
  fi
  echo "No project configured. Run: devdash init" >&2
  exit "$DD_EXIT_CONFIG"
}

dd_get_token() {
  # Ensure config directory has secure permissions
  if [ -d "$DD_CONFIG_DIR" ]; then
    local dir_perms
    dir_perms=$(stat -f '%Lp' "$DD_CONFIG_DIR" 2>/dev/null || stat -c '%a' "$DD_CONFIG_DIR" 2>/dev/null)
    if [ -n "$dir_perms" ] && [ "$dir_perms" != "700" ]; then
      echo "Warning: ${DD_CONFIG_DIR} has permissions $dir_perms (should be 700). Fixing..." >&2
      chmod 700 "$DD_CONFIG_DIR"
    fi
  fi
  if [ -f "$DD_TOKEN_FILE" ]; then
    cat "$DD_TOKEN_FILE"
  else
    echo "Not logged in. Run: devdash login" >&2
    exit "$DD_EXIT_CONFIG"
  fi
}

dd_api() {
  local method=$1 endpoint=$2
  shift 2
  local token url tmpfile http_code body
  token=$(dd_get_token) || return $?
  url="$(dd_api_url)/api${endpoint}"
  tmpfile=$(mktemp)
  http_code=$(curl -s -o "$tmpfile" -w '%{http_code}' -X "$method" \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "$url" "$@" 2>/dev/null) || {
    rm -f "$tmpfile"
    echo "Error: could not connect to $(dd_api_url)" >&2
    exit "$DD_EXIT_API"
  }
  body=$(cat "$tmpfile")
  rm -f "$tmpfile"

  if [ "$http_code" -ge 200 ] && [ "$http_code" -lt 300 ]; then
    echo "$body"
  else
    local msg
    msg=$(echo "$body" | jq -r '.error // .message // empty' 2>/dev/null)
    if [ -n "$msg" ]; then
      echo "API error ($http_code): $msg" >&2
    else
      echo "API error ($http_code): $body" >&2
    fi
    exit "$DD_EXIT_API"
  fi
}

# Safe jq wrapper — handles non-JSON input gracefully
dd_jq() {
  jq "$@" 2>/dev/null || {
    echo "Error: unexpected non-JSON response from API" >&2
    exit "$DD_EXIT_API"
  }
}

# Fetch all beads for a project (handles pagination)
dd_fetch_beads() {
  local pid="$1"
  local all="[]" cursor="" page
  while true; do
    local url="/beads?projectId=${pid}&limit=500"
    [ -n "$cursor" ] && url="${url}&cursor=$(printf '%s' "$cursor" | jq -sRr @uri)"
    page=$(dd_api GET "$url") || return $?
    local data
    data=$(echo "$page" | dd_jq '.data // .')
    all=$(echo "$all" "$data" | jq -s '.[0] + .[1]')
    cursor=$(echo "$page" | dd_jq -r '.nextCursor // empty')
    if [ -z "$cursor" ] || [ "$cursor" = "null" ]; then
      break
    fi
  done
  echo "$all"
}

# Fetch all jobs for a project (unwraps paginated response)
dd_fetch_jobs() {
  local pid="$1" result
  result=$(dd_api GET "/jobs?projectId=${pid}") || return $?
  echo "$result" | dd_jq '.data // .'
}

# Resolve a bead ID: handles dev-dash-* local IDs and UUID prefixes
# Usage: uuid=$(dd_resolve_id "$bead_id" "$project_id" ["$cached_beads"])
# Pass cached_beads (JSON array) as $3 to skip the API fetch.
dd_resolve_id() {
  local bead_id="$1" pid="$2" cached_beads="${3:-}"

  # Need beads for all lookups (including full UUID validation)
  local all_beads
  if [ -n "$cached_beads" ]; then
    all_beads="$cached_beads"
  else
    all_beads=$(dd_fetch_beads "$pid")
  fi

  # dev-dash-* local IDs — resolve via localBeadId field
  if [[ "$bead_id" == dev-dash-* ]]; then
    local uuid
    uuid=$(echo "$all_beads" | jq -r --arg b "$bead_id" '.[] | select(.localBeadId == $b) | .id')
    if [ -z "$uuid" ]; then
      echo "Bead not found: $bead_id" >&2
      return 1
    fi
    echo "$uuid"
    return
  fi

  # Match by prefix (works for both full UUIDs and short prefixes)
  local matches
  matches=$(echo "$all_beads" | jq -r --arg b "$bead_id" '[.[] | select(.id | startswith($b))] | .[].id')

  if [ -z "$matches" ]; then
    echo "Bead not found in this project: $bead_id" >&2
    echo "Hint: check your working directory or use DD_PROJECT_ID" >&2
    return 1
  fi

  local count
  count=$(echo "$matches" | wc -l | tr -d ' ')

  if [ "$count" -gt 1 ]; then
    echo "Ambiguous prefix '$bead_id' matches $count beads:" >&2
    echo "$matches" | head -5 >&2
    return 1
  fi

  echo "$matches"
}

# ── Detect command name ──────────────────────────────────────────
# If user has 'dd' aliased to devdash, use 'dd' in output; otherwise 'devdash'
dd_cmd_name() {
  if alias dd 2>/dev/null | grep -q devdash 2>/dev/null; then
    echo "dd"
  elif type dd 2>/dev/null | grep -q devdash 2>/dev/null; then
    echo "dd"
  else
    echo "devdash"
  fi
}

# ── Commands ─────────────────────────────────────────────────────

dd_version() {
  echo "devdash ${DD_VERSION}"
}

dd_login() {
  local no_browser=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-browser) no_browser=true; shift ;;
      *) shift ;;
    esac
  done

  local nonce
  nonce=$(openssl rand -hex 16)
  local tmpfile
  tmpfile=$(mktemp)
  local api_url
  api_url=$(dd_api_url)

  # Find an available port (try 18787-18792)
  local port=""
  for try_port in 18787 18788 18789 18790 18791 18792; do
    if ! python3 -c "import socket; s=socket.socket(); s.settimeout(0.1); s.connect(('127.0.0.1',$try_port)); s.close()" 2>/dev/null; then
      port=$try_port
      break
    fi
  done
  if [ -z "$port" ]; then
    echo "Error: all callback ports 18787-18792 are in use" >&2
    exit "$DD_EXIT_CONFIG"
  fi

  # Start a temporary Python HTTP server for the OAuth callback (120s timeout)
  python3 -c "
import http.server, urllib.parse, threading, signal, sys

# Exit cleanly on SIGTERM/SIGINT — no traceback
signal.signal(signal.SIGTERM, lambda *a: sys.exit(0))
signal.signal(signal.SIGINT, lambda *a: sys.exit(0))

class H(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        qs = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
        token = (qs.get('token') or [None])[0]
        nonce_rx = (qs.get('nonce') or [None])[0]
        if token and nonce_rx == '${nonce}':
            with open('${tmpfile}', 'w') as f:
                f.write(token)
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            self.wfile.write(b'''<html><body style=\"font-family:system-ui;display:flex;justify-content:center;align-items:center;height:100vh;margin:0\">
<div style=\"text-align:center\"><h1>Authenticated!</h1><p>You can close this tab and return to your terminal.</p></div>
</body></html>''')
        else:
            self.send_response(400)
            self.end_headers()
            self.wfile.write(b'Invalid callback')
        threading.Thread(target=self.server.shutdown).start()
    def log_message(self, *a): pass

s = http.server.HTTPServer(('127.0.0.1', ${port}), H)
# Auto-shutdown after 120s if no callback received (daemon so process can exit early)
t = threading.Timer(120, s.shutdown)
t.daemon = True
t.start()
s.serve_forever()
" &
  local server_pid=$!

  # Clean up server on Ctrl+C
  trap 'printf "\nCancelled.\n"; kill $server_pid 2>/dev/null; rm -f "$tmpfile"; exit 130' INT

  local url="${api_url}/api/auth/cli-token?port=${port}&nonce=${nonce}"
  if [ "$no_browser" = true ]; then
    echo "Open this URL in your browser (e.g. incognito window):"
    echo ""
    echo "  $url"
    echo ""
  else
    echo "Opening browser for authentication..."
    open "$url" 2>/dev/null || xdg-open "$url" 2>/dev/null || echo "Open this URL in your browser: $url"
  fi
  echo "Waiting for callback (up to 2 minutes)..."

  # Wait for server to exit (callback received or timeout)
  wait "$server_pid" 2>/dev/null || true
  trap - INT

  if [ -s "$tmpfile" ]; then
    mkdir -p "$DD_CONFIG_DIR"
    chmod 700 "$DD_CONFIG_DIR"
    cp "$tmpfile" "$DD_TOKEN_FILE"
    chmod 600 "$DD_TOKEN_FILE"
    rm -f "$tmpfile"
    echo "Logged in successfully! Token stored in ${DD_TOKEN_FILE}"

    # Auto-init if in a git repo without .devdash
    if [ ! -f "$DD_PROJECT_FILE" ] && git rev-parse --is-inside-work-tree &>/dev/null; then
      echo ""
      dd_init
    fi
  else
    rm -f "$tmpfile"
    echo "Login failed or timed out." >&2
    exit "$DD_EXIT_API"
  fi
}

# Helper for dd_init: interactively create a new project and echo its ID.
# Uses $remote (from caller scope) if available.
dd_init_create_project() {
  local default_name
  if [ -n "${remote:-}" ]; then
    default_name=$(basename "$remote")
  else
    default_name=$(basename "$(pwd)")
  fi

  local name
  printf "Project name [%s]: " "$default_name" >&2
  read -r name </dev/tty 2>/dev/null || name=""
  name="${name:-$default_name}"

  local repo="${remote:-}"

  local body
  body=$(jq -n \
    --arg name "$name" \
    --arg githubRepo "$repo" \
    '{name: $name} + (if $githubRepo != "" then {githubRepo: $githubRepo} else {} end)')

  local result
  result=$(dd_api POST "/projects" -d "$body")
  local id
  id=$(echo "$result" | jq -r '.id')
  local pname
  pname=$(echo "$result" | jq -r '.name')
  echo "Created project: ${pname} (${id})" >&2
  echo "$id"
}

dd_init() {
  local selector="${1:-}"

  # Fetch projects
  local projects
  projects=$(dd_api GET "/projects" 2>/dev/null) || {
    echo "Failed to fetch projects. Are you logged in? Run: devdash login" >&2
    exit "$DD_EXIT_API"
  }

  local pid="" remote=""

  # Mode A: explicit argument — match by UUID, prefix, or name
  if [ -n "$selector" ]; then
    # Try full UUID match
    pid=$(echo "$projects" | jq -r --arg s "$selector" \
      '.[] | select(.id == $s) | .id' 2>/dev/null | head -1)

    # Try prefix match
    if [ -z "$pid" ]; then
      local matches
      matches=$(echo "$projects" | jq -r --arg s "$selector" \
        '[.[] | select(.id | startswith($s))] | length' 2>/dev/null)
      if [ "$matches" = "1" ]; then
        pid=$(echo "$projects" | jq -r --arg s "$selector" \
          '.[] | select(.id | startswith($s)) | .id' 2>/dev/null)
      elif [ "$matches" -gt 1 ] 2>/dev/null; then
        echo "Multiple projects match prefix '${selector}':" >&2
        echo "$projects" | jq -r --arg s "$selector" \
          '.[] | select(.id | startswith($s)) | "  \(.id)  \(.name)"'
        echo "" >&2
        echo "Be more specific, e.g.: devdash init <longer-prefix>" >&2
        exit "$DD_EXIT_USER"
      fi
    fi

    # Try name match (case-insensitive)
    if [ -z "$pid" ]; then
      local name_matches
      name_matches=$(echo "$projects" | jq -r --arg s "$selector" \
        '[.[] | select(.name | ascii_downcase == ($s | ascii_downcase))] | length' 2>/dev/null)
      if [ "$name_matches" = "1" ]; then
        pid=$(echo "$projects" | jq -r --arg s "$selector" \
          '.[] | select(.name | ascii_downcase == ($s | ascii_downcase)) | .id' 2>/dev/null)
      elif [ "$name_matches" -gt 1 ] 2>/dev/null; then
        echo "Multiple projects match name '${selector}':" >&2
        echo "$projects" | jq -r --arg s "$selector" \
          '.[] | select(.name | ascii_downcase == ($s | ascii_downcase)) | "  \(.id)  \(.name)"'
        exit "$DD_EXIT_USER"
      fi
    fi

    if [ -z "$pid" ]; then
      echo "No project matches '${selector}'." >&2
      echo "" >&2
      echo "Available projects:" >&2
      echo "$projects" | jq -r '.[] | "  \(.id | .[0:8])  \(.name)  (\(.githubRepo // "no repo"))"' >&2
      exit "$DD_EXIT_USER"
    fi
  fi

  # Mode B: auto-match by git remote (case-insensitive)
  if [ -z "$pid" ]; then
    if git rev-parse --is-inside-work-tree &>/dev/null; then
      remote=$(git remote get-url origin 2>/dev/null | sed -E 's#.*github\.com[:/](.*)\.git$#\1#; s#.*github\.com[:/](.*)$#\1#') || remote=""
    fi

    if [ -n "$remote" ]; then
      pid=$(echo "$projects" | jq -r --arg r "$remote" \
        '.[] | select((.githubRepo // "") | ascii_downcase == ($r | ascii_downcase)) | .id' 2>/dev/null | head -1)
    fi
  fi

  # Mode C: interactive / hint fallback
  if [ -z "$pid" ]; then
    local count
    count=$(echo "$projects" | jq 'length' 2>/dev/null)

    if [ "$count" = "0" ]; then
      if [ -t 0 ]; then
        echo "No projects found. Let's create one."
        pid=$(dd_init_create_project)
      else
        echo "No projects found. Create one first:" >&2
        echo "  devdash project create --name=\"My Project\"" >&2
        exit "$DD_EXIT_CONFIG"
      fi
    fi

    if [ -z "$pid" ]; then
      echo "Could not auto-detect project.${remote:+ Git remote: ${remote}}"
      echo ""
      echo "Available projects:"

      # Show numbered list
      echo "$projects" | jq -r 'to_entries[] | "  \(.key + 1). \(.value.name)  (\(.value.githubRepo // "no repo"))  [\(.value.id | .[0:8])]"'
      local create_num=$(( count + 1 ))
      echo "  ${create_num}. Create new project"
      echo ""

      if [ -t 0 ]; then
        printf "Select project number: "
        read -r choice </dev/tty 2>/dev/null || { echo "No input available." >&2; exit "$DD_EXIT_USER"; }
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$create_num" ]; then
          if [ "$choice" -eq "$create_num" ]; then
            pid=$(dd_init_create_project)
          else
            pid=$(echo "$projects" | jq -r ".[$((choice - 1))].id" 2>/dev/null)
          fi
        else
          echo "Invalid selection." >&2
          exit "$DD_EXIT_USER"
        fi
      else
        echo "Run: devdash init <name-or-id>" >&2
        exit "$DD_EXIT_USER"
      fi
    fi
  fi

  # Write config
  local pname
  pname=$(echo "$projects" | jq -r --arg id "$pid" '.[] | select(.id == $id) | .name' 2>/dev/null)
  if [ -z "$pname" ]; then
    pname=$(dd_api GET "/projects/${pid}" | jq -r '.name' 2>/dev/null)
  fi
  local api_url
  api_url=$(dd_api_url)
  jq -n --arg url "$api_url" --arg pid "$pid" '{api_url: $url, project_id: $pid}' > "$DD_PROJECT_FILE"
  echo "Initialized: ${pname} -> .devdash"

  dd_maybe_offer_alias
  dd_maybe_offer_agent_setup
}

dd_list() {
  local pid
  pid=$(dd_project_id)
  local status_filter="" since_cutoff=""

  local parent_filter=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status=*) status_filter="${1#--status=}" ;;
      --since=*) since_cutoff=$(dd_parse_since "${1#--since=}") || exit 1 ;;
      --parent=*) parent_filter="${1#--parent=}" ;;
      *) status_filter="${1#--status=}" ;;
    esac
    shift
  done

  local beads
  beads=$(dd_fetch_beads "$pid")

  # Resolve parent prefix to full UUID (reuse already-fetched beads)
  if [ -n "$parent_filter" ]; then
    parent_filter=$(dd_resolve_id "$parent_filter" "$pid" "$beads") || exit 1
  fi

  if [ -n "$status_filter" ]; then
    beads=$(echo "$beads" | jq --arg s "$status_filter" '[.[] | select(.status == $s)]')
  fi

  if [ -n "$since_cutoff" ]; then
    beads=$(echo "$beads" | jq --arg c "$since_cutoff" '[.[] | select(.updatedAt >= $c)]')
  fi

  if [ -n "$parent_filter" ]; then
    beads=$(echo "$beads" | jq --arg p "$parent_filter" '[.[] | select(.parentBeadId == $p)]')
  fi

  echo "$beads" | jq -r '.[] | "\(.status | if . == "pending" then "○" elif . == "in_progress" then "●" elif . == "completed" then "✓" else "?" end) \(.localBeadId // .id) [P\(.priority)] [\(.beadType // "task")] - \(.subject)\(if (.blockedBy | length) > 0 then " (blocked)" else "" end)"'
}

dd_ready() {
  local since_cutoff=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since=*) since_cutoff=$(dd_parse_since "${1#--since=}") || exit 1 ;;
    esac
    shift
  done

  local pid
  pid=$(dd_project_id)
  local beads
  beads=$(dd_fetch_beads "$pid")

  echo "$beads" | jq -r --arg c "$since_cutoff" '
    ([.[] | select(.status == "completed") | .id]) as $done |
    [.[] | select(.status == "pending")
         | select((.blockedBy | length) == 0 or ([.blockedBy[] | IN($done[])] | all))]
    | [.[] | select((.beadType // "task") != "thought")]
    | if $c != "" then [.[] | select(.createdAt >= $c)] else . end
    | sort_by(-(.automabilityScore // 0), .priority)
    | .[]
    | "○ \(.localBeadId // .id) [P\(.priority)]\(if .automabilityGrade then " [\(.automabilityGrade)]" else "" end) [\(.beadType // "task")] - \(.subject)"
  '
}

dd_show() {
  if [ -z "${1:-}" ]; then
    echo "Usage: devdash show <bead-id>" >&2
    exit "$DD_EXIT_USER"
  fi
  local pid
  pid=$(dd_project_id)
  local uuid
  uuid=$(dd_resolve_id "$1" "$pid") || exit 1

  local bead
  bead=$(dd_api GET "/beads/${uuid}?projectId=${pid}")

  echo "$bead" | jq '{
    id: .id,
    localId: .localBeadId,
    subject: .subject,
    description: .description,
    status: .status,
    priority: .priority,
    assignedTo: .assignedTo,
    beadType: .beadType,
    parentBeadId: .parentBeadId,
    blockedBy: .blockedBy,
    blocks: .blocks,
    preInstructions: .preInstructions,
    completionResult: .completionResult,
    createdAt: .createdAt,
    updatedAt: .updatedAt
  }
  + (if .staleSince != null then {staleSince: .staleSince, staleMinutes: .staleMinutes} else {} end)
  + (if .automabilityGrade != null then {
      burnIntelligence: {
        complexityScore: .complexityScore,
        automabilityScore: .automabilityScore,
        automabilityGrade: .automabilityGrade,
        factors: .burnScores,
        scoredAt: .burnScoredAt
      }
    } else {} end)'
}

dd_find() {
  if [ -z "${1:-}" ]; then
    echo "Usage: devdash find <bead-uuid>" >&2
    echo "Look up a bead across all accessible projects (full UUID required)." >&2
    exit "$DD_EXIT_USER"
  fi

  local bead_id="$1"

  # Require full UUID format
  if [[ ${#bead_id} -ne 36 || "$bead_id" != *-*-*-*-* ]]; then
    echo "Error: devdash find requires a full UUID (prefix lookup not supported across projects)." >&2
    echo "Hint: use 'devdash show <prefix>' within a specific project instead." >&2
    exit "$DD_EXIT_USER"
  fi

  local bead
  bead=$(dd_api GET "/beads/${bead_id}") || exit 1

  # Get project name for context
  local project_id project_name
  project_id=$(echo "$bead" | dd_jq -r '.projectId // empty')
  if [ -n "$project_id" ]; then
    local project_info
    project_info=$(dd_api GET "/projects" 2>/dev/null) || true
    project_name=$(echo "$project_info" | dd_jq -r --arg pid "$project_id" '.[] | select(.id == $pid) | .name // empty' 2>/dev/null)
  fi

  echo "$bead" | jq --arg pname "${project_name:-unknown}" '{
    id: .id,
    projectId: .projectId,
    projectName: $pname,
    localId: .localBeadId,
    subject: .subject,
    description: .description,
    status: .status,
    priority: .priority,
    assignedTo: .assignedTo,
    beadType: .beadType,
    parentBeadId: .parentBeadId,
    blockedBy: .blockedBy,
    blocks: .blocks,
    preInstructions: .preInstructions,
    completionResult: .completionResult,
    createdAt: .createdAt,
    updatedAt: .updatedAt
  }
  + (if .staleSince != null then {staleSince: .staleSince, staleMinutes: .staleMinutes} else {} end)
  + (if .automabilityGrade != null then {
      burnIntelligence: {
        complexityScore: .complexityScore,
        automabilityScore: .automabilityScore,
        automabilityGrade: .automabilityGrade,
        factors: .burnScores,
        scoredAt: .burnScoredAt
      }
    } else {} end)'
}

dd_score() {
  local pid
  pid=$(dd_project_id)

  if [ -z "${1:-}" ]; then
    # Bulk score all unscored beads in project
    local result
    result=$(dd_api POST "/projects/${pid}/beads/score" -d '{}')
    local scored
    scored=$(echo "$result" | jq -r '.scored')
    if [ "$scored" = "0" ]; then
      echo "No unscored beads found."
    else
      echo "Scored $scored beads:"
      echo "$result" | jq -r '.results[] | "  \(.beadId | .[0:8])  \(.automabilityGrade) (\(.automabilityScore)/100)  complexity=\(.complexityScore)"'
    fi
  else
    # Score a specific bead
    local uuid
    uuid=$(dd_resolve_id "$1" "$pid") || exit 1
    local result
    result=$(dd_api POST "/projects/${pid}/beads/${uuid}/score" -d '{}')
    echo "$result" | jq '{
      beadId: .beadId,
      complexityScore: .complexityScore,
      automabilityScore: .automabilityScore,
      automabilityGrade: .automabilityGrade,
      factors: .factors
    }'
  fi
}

dd_diagnose() {
  if [ -z "${1:-}" ]; then
    echo "Usage: devdash diagnose <bead-id>" >&2
    exit "$DD_EXIT_USER"
  fi

  local pid
  pid=$(dd_project_id)
  local uuid
  uuid=$(dd_resolve_id "$1" "$pid") || exit 1

  # Fetch bead details
  local bead
  bead=$(dd_api GET "/beads/${uuid}?projectId=${pid}")

  # Display bead summary
  echo "── Bead ──"
  echo "$bead" | jq -r '"\(.id[0:8])  \(.subject)  [\(.status)] [P\(.priority)] [\(.beadType // "task")]"'
  echo ""

  # Fetch and filter jobs for this bead
  local all_jobs bead_jobs job_count
  all_jobs=$(dd_fetch_jobs "$pid")
  bead_jobs=$(echo "$all_jobs" | jq --arg bid "$uuid" '[.[] | select(.bead_id == $bid)]')
  job_count=$(echo "$bead_jobs" | jq 'length')

  echo "── Jobs ($job_count) ──"
  if [ "$job_count" -eq 0 ]; then
    echo "No jobs found"
  else
    echo "$bead_jobs" | jq -r '.[] | "\(.status | if . == "completed" then "✓" elif . == "failed" then "✗" elif . == "running" then "●" else "○" end) \(.id[0:8])  [\(.status)]  \(.created_at // "")"'
  fi
  echo ""

  # Find latest failed job
  local failed
  failed=$(echo "$bead_jobs" | jq '[.[] | select(.status == "failed")] | sort_by(.created_at) | last // empty')

  if [ -z "$failed" ]; then
    echo "No failures found"
    return
  fi

  local failed_id
  failed_id=$(echo "$failed" | jq -r '.id')

  # Fetch full job for details and output_log
  local full_job
  full_job=$(dd_api GET "/jobs/${failed_id}")

  echo "── Latest Failure: $(echo "$failed" | jq -r '.id[0:8]') ──"
  echo "Error: $(echo "$full_job" | jq -r '.error // "unknown"')"

  # Show failure analysis if present
  local analysis
  analysis=$(echo "$full_job" | jq -r '.failureAnalysis.summary // empty')
  if [ -n "$analysis" ]; then
    echo "Analysis: $analysis"
  fi

  local log_output
  log_output=$(echo "$full_job" | jq -r '.output_log // empty')
  if [ -n "$log_output" ]; then
    echo ""
    echo "Log (last 30 lines):"
    echo "$log_output" | tail -n 30 | sed 's/^/  /'
  fi
}

dd_create() {
  local pid
  pid=$(dd_project_id)
  local title="" type="task" priority=2 description="" parent="" due="" estimate=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title=*) title="${1#--title=}" ;;
      --type=*) type="${1#--type=}" ;;
      --priority=*) priority="${1#--priority=}" ;;
      --description=*) description="${1#--description=}" ;;
      --parent=*) parent="${1#--parent=}" ;;
      --due=*) due="${1#--due=}" ;;
      --estimate=*) estimate="${1#--estimate=}" ;;
      *) title="$1" ;;
    esac
    shift
  done

  if [ -z "$title" ]; then
    echo "Usage: devdash create --title=\"...\" [--type=task|bug|feature] [--priority=0-4] [--description=\"...\"]" >&2
    exit "$DD_EXIT_USER"
  fi

  # Validate priority is an integer 0-4
  if ! [[ "$priority" =~ ^[0-4]$ ]]; then
    echo "Error: priority must be 0-4 (got: $priority)" >&2
    exit "$DD_EXIT_USER"
  fi

  # Resolve parent short ID to full UUID
  if [ -n "$parent" ]; then
    parent=$(dd_resolve_id "$parent" "$pid") || exit 1
  fi

  local body
  body=$(jq -n \
    --arg projectId "$pid" \
    --arg subject "$title" \
    --arg description "$description" \
    --argjson priority "$priority" \
    --arg beadType "$type" \
    --arg parentBeadId "$parent" \
    --arg dueDate "$due" \
    --arg estimatedMinutes "$estimate" \
    '{projectId: $projectId, subject: $subject, description: $description, priority: $priority, beadType: $beadType}
      + (if $parentBeadId != "" then {parentBeadId: $parentBeadId} else {} end)
      + (if $dueDate != "" then {dueDate: $dueDate} else {} end)
      + (if $estimatedMinutes != "" then {estimatedMinutes: ($estimatedMinutes | tonumber)} else {} end)')

  local result
  result=$(dd_api POST "/beads" -d "$body")
  local id
  id=$(echo "$result" | jq -r '.id')
  local subject
  subject=$(echo "$result" | jq -r '.subject')
  echo "Created: ${id} - ${subject}"
}

dd_update() {
  local bead_id="$1"
  shift
  local pid
  pid=$(dd_project_id)
  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  local body
  body=$(jq -n --arg pid "$pid" '{projectId: $pid}')

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status=*) body=$(echo "$body" | jq --arg v "${1#--status=}" '. + {status: $v}') ;;
      --priority=*)
        local pval="${1#--priority=}"
        if ! [[ "$pval" =~ ^[0-4]$ ]]; then
          echo "Error: priority must be 0-4 (got: $pval)" >&2
          exit "$DD_EXIT_USER"
        fi
        body=$(echo "$body" | jq --argjson v "$pval" '. + {priority: $v}')
        ;;
      --owner=*) body=$(echo "$body" | jq --arg v "${1#--owner=}" '. + {assignedTo: $v}') ;;
      --title=*) body=$(echo "$body" | jq --arg v "${1#--title=}" '. + {subject: $v}') ;;
      --description=*) body=$(echo "$body" | jq --arg v "${1#--description=}" '. + {description: $v}') ;;
      --pre-instructions=*) body=$(echo "$body" | jq --arg v "${1#--pre-instructions=}" '. + {preInstructions: $v}') ;;
      --parent=*)
        local parent_uuid
        parent_uuid=$(dd_resolve_id "${1#--parent=}" "$pid") || exit 1
        body=$(echo "$body" | jq --arg v "$parent_uuid" '. + {parentBeadId: $v}')
        ;;
      --due=*) body=$(echo "$body" | jq --arg v "${1#--due=}" '. + {dueDate: $v}') ;;
      --estimate=*) body=$(echo "$body" | jq --arg v "${1#--estimate=}" '. + {estimatedMinutes: ($v | tonumber)}') ;;
    esac
    shift
  done

  dd_api PATCH "/beads/${uuid}" -d "$body" > /dev/null
  echo "Updated: ${uuid}"
}

dd_close() {
  local pr="" commit="" summary=""
  local bead_ids=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pr=*) pr="${1#--pr=}" ;;
      --commit=*) commit="${1#--commit=}" ;;
      --summary=*) summary="${1#--summary=}" ;;
      *) bead_ids+=("$1") ;;
    esac
    shift
  done

  if [ ${#bead_ids[@]} -eq 0 ]; then
    echo "Usage: devdash close <id> [<id>...] [--pr=URL] [--commit=SHA] [--summary=\"...\"]" >&2
    exit "$DD_EXIT_USER"
  fi

  # Build completionResult JSON when any flags are provided
  local completion_result=""
  if [ -n "$pr" ] || [ -n "$commit" ] || [ -n "$summary" ]; then
    completion_result=$(jq -n \
      --arg pr "$pr" \
      --arg commit "$commit" \
      --arg summary "$summary" \
      '{} + (if $pr != "" then {prUrl: $pr} else {} end)
         + (if $commit != "" then {commitSha: $commit} else {} end)
         + (if $summary != "" then {summary: $summary} else {} end)')
  fi

  local pid
  pid=$(dd_project_id)

  # Pre-fetch beads once for ID resolution (avoids N fetches)
  local cached_beads
  cached_beads=$(dd_fetch_beads "$pid")

  # Resolve all IDs upfront
  local uuids=()
  for bead_id in "${bead_ids[@]}"; do
    local uuid
    uuid=$(dd_resolve_id "$bead_id" "$pid" "$cached_beads") || { echo "Skipping: $bead_id" >&2; continue; }
    uuids+=("$uuid")
  done

  if [ ${#uuids[@]} -eq 0 ]; then
    echo "No valid beads to close" >&2
    exit "$DD_EXIT_USER"
  fi

  # Single bead: use individual PATCH (simpler, same as before)
  if [ ${#uuids[@]} -eq 1 ]; then
    local body
    if [ -n "$completion_result" ]; then
      body=$(jq -n \
        --arg pid "$pid" \
        --argjson cr "$completion_result" \
        '{projectId: $pid, status: "completed", completionResult: $cr}')
    else
      body=$(jq -n --arg pid "$pid" '{projectId: $pid, status: "completed"}')
    fi
    dd_api PATCH "/beads/${uuids[0]}" -d "$body" > /dev/null
    echo "Closed: ${uuids[0]}"
    return
  fi

  # Multiple beads: use bulk/close endpoint (single API call)
  local beads_json="[]"
  for uuid in "${uuids[@]}"; do
    if [ -n "$completion_result" ]; then
      beads_json=$(echo "$beads_json" | jq --arg id "$uuid" --argjson cr "$completion_result" \
        '. + [{id: $id} + $cr]')
    else
      beads_json=$(echo "$beads_json" | jq --arg id "$uuid" '. + [{id: $id}]')
    fi
  done

  local body
  body=$(jq -n --arg pid "$pid" --argjson beads "$beads_json" \
    '{projectId: $pid, beads: $beads}')

  local result
  result=$(dd_api POST "/beads/bulk/close" -d "$body")

  # Parse and display results
  local succeeded failed
  succeeded=$(echo "$result" | jq -r '.summary.succeeded // 0')
  failed=$(echo "$result" | jq -r '.summary.failed // 0')

  # Show individual results
  echo "$result" | jq -r '.results[] | if .success then "Closed: \(.id)" else "Failed: \(.id) — \(.error // "unknown error")" end'

  if [ "$failed" -gt 0 ]; then
    echo "Summary: ${succeeded} closed, ${failed} failed" >&2
  fi
}

dd_stale() {
  local since_cutoff=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since=*) since_cutoff=$(dd_parse_since "${1#--since=}") || exit 1 ;;
    esac
    shift
  done

  local pid
  pid=$(dd_project_id)
  local beads
  beads=$(dd_fetch_beads "$pid")

  # Filter to in_progress beads that have staleMinutes > 0
  local stale
  stale=$(echo "$beads" | jq --arg c "$since_cutoff" '
    [.[] | select(.status == "in_progress" and .staleMinutes != null and .staleMinutes > 0)]
    | if $c != "" then [.[] | select(.updatedAt >= $c)] else . end
    | sort_by(-.staleMinutes)')

  local count
  count=$(echo "$stale" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No stale in-progress issues found."
    return
  fi

  echo "Stale in-progress issues ($count):"
  echo ""
  echo "$stale" | jq -r '.[] | "  ⚠ \(.localBeadId // .id) — \(.subject)\n    Stale for \(.staleMinutes)m (since \(.staleSince // "unknown"))\n"'
}

dd_report() {
  local bead_id="${1:-}"
  if [ -n "$bead_id" ]; then shift; fi
  local pid
  pid=$(dd_project_id)

  if [ -z "$bead_id" ]; then
    echo "Usage: devdash report <id> --status=code_complete|committed|pushed|error [--summary=\"...\"] [--files-changed=N] [--branch=name] [--commit=sha] [--error=\"...\"]" >&2
    exit "$DD_EXIT_USER"
  fi

  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  local status="" summary="" files_changed="" branch="" commit="" error_msg=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status=*) status="${1#--status=}" ;;
      --summary=*) summary="${1#--summary=}" ;;
      --files-changed=*) files_changed="${1#--files-changed=}" ;;
      --branch=*) branch="${1#--branch=}" ;;
      --commit=*) commit="${1#--commit=}" ;;
      --error=*) error_msg="${1#--error=}" ;;
    esac
    shift
  done

  if [ -z "$status" ]; then
    echo "Usage: devdash report <id> --status=code_complete|committed|pushed|error" >&2
    exit "$DD_EXIT_USER"
  fi

  local body
  body=$(jq -n \
    --arg projectId "$pid" \
    --arg status "$status" \
    --arg summary "$summary" \
    --arg filesChanged "$files_changed" \
    --arg branch "$branch" \
    --arg commitSha "$commit" \
    --arg error "$error_msg" \
    '{projectId: $projectId, status: $status}
      + (if $summary != "" then {summary: $summary} else {} end)
      + (if $filesChanged != "" then {filesChanged: ($filesChanged | tonumber)} else {} end)
      + (if $branch != "" then {branch: $branch} else {} end)
      + (if $commitSha != "" then {commitSha: $commitSha} else {} end)
      + (if $error != "" then {error: $error} else {} end)')

  dd_api POST "/beads/${uuid}/report" -d "$body" > /dev/null
  echo "Report submitted: ${status} for ${uuid}"
}

dd_delete() {
  local force=false
  local cascade=false
  local bead_ids=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=true ;;
      --cascade) cascade=true ;;
      *) bead_ids+=("$1") ;;
    esac
    shift
  done

  if [ ${#bead_ids[@]} -eq 0 ]; then
    echo "Usage: devdash delete <bead-id> [<bead-id>...] [--force] [--cascade]" >&2
    exit "$DD_EXIT_USER"
  fi

  local pid
  pid=$(dd_project_id)

  # Pre-fetch beads once for ID resolution (avoids N fetches)
  local cached_beads
  cached_beads=$(dd_fetch_beads "$pid")

  for bead_id in "${bead_ids[@]}"; do
    local uuid
    uuid=$(dd_resolve_id "$bead_id" "$pid" "$cached_beads") || { echo "Skipping: $bead_id" >&2; continue; }

    if [ "$force" != true ]; then
      local bead subject
      bead=$(dd_api GET "/beads/${uuid}?projectId=${pid}")
      subject=$(echo "$bead" | dd_jq -r '.subject')
      if [ "$cascade" = true ]; then
        printf "Delete '%s' and all children? [y/N] " "$subject"
      else
        printf "Delete '%s'? [y/N] " "$subject"
      fi
      read -r answer </dev/tty 2>/dev/null || answer="n"
      case "$answer" in
        [Yy]|[Yy]es) ;;
        *) echo "Skipped: $bead_id"; continue ;;
      esac
    fi

    local delete_qs=""
    [ "$cascade" = true ] && delete_qs="?cascade=true"
    dd_api DELETE "/beads/${uuid}${delete_qs}" > /dev/null
    echo "Deleted: ${uuid}"
  done
}

dd_dep_add() {
  local issue="${1:-}" depends_on="${2:-}"
  if [ -z "$issue" ] || [ -z "$depends_on" ]; then
    echo "Usage: devdash dep add <issue> <depends-on>" >&2
    exit "$DD_EXIT_USER"
  fi
  local pid
  pid=$(dd_project_id)

  # Pre-fetch beads once for both resolutions
  local cached_beads
  cached_beads=$(dd_fetch_beads "$pid")

  local issue_uuid dep_uuid
  issue_uuid=$(dd_resolve_id "$issue" "$pid" "$cached_beads") || exit 1
  # For the blocker: if it's a full UUID, pass through directly (supports cross-project deps).
  # Only resolve within current project if it's a short prefix or local ID.
  if [[ ${#depends_on} -eq 36 && "$depends_on" == *-*-*-*-* ]]; then
    dep_uuid="$depends_on"
  else
    dep_uuid=$(dd_resolve_id "$depends_on" "$pid" "$cached_beads") || exit 1
  fi

  local body
  body=$(jq -n --arg pid "$pid" --arg dep "$dep_uuid" '{projectId: $pid, blockedBy: $dep}')
  dd_api POST "/beads/${issue_uuid}/dependencies" -d "$body" > /dev/null
  echo "Added dependency: ${issue} depends on ${depends_on}"
}

dd_dep_remove() {
  local issue="${1:-}" depends_on="${2:-}"
  if [ -z "$issue" ] || [ -z "$depends_on" ]; then
    echo "Usage: devdash dep remove <issue> <depends-on>" >&2
    exit "$DD_EXIT_USER"
  fi
  local pid
  pid=$(dd_project_id)

  # Pre-fetch beads once for both resolutions
  local cached_beads
  cached_beads=$(dd_fetch_beads "$pid")

  local issue_uuid dep_uuid
  issue_uuid=$(dd_resolve_id "$issue" "$pid" "$cached_beads") || exit 1
  # Same cross-project passthrough as dep add
  if [[ ${#depends_on} -eq 36 && "$depends_on" == *-*-*-*-* ]]; then
    dep_uuid="$depends_on"
  else
    dep_uuid=$(dd_resolve_id "$depends_on" "$pid" "$cached_beads") || exit 1
  fi

  dd_api DELETE "/beads/${issue_uuid}/dependencies/${dep_uuid}?projectId=${pid}" > /dev/null
  echo "Removed dependency: ${issue} no longer depends on ${depends_on}"
}

dd_comment() {
  local bead_id="${1:-}"
  if [ -n "$bead_id" ]; then shift; fi
  local pid
  pid=$(dd_project_id)

  if [ -z "$bead_id" ]; then
    echo "Usage: devdash comment <bead-id> --body=\"...\"" >&2
    exit "$DD_EXIT_USER"
  fi

  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  local body_text=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --body=*) body_text="${1#--body=}" ;;
      *) body_text="$1" ;;
    esac
    shift
  done

  if [ -z "$body_text" ]; then
    echo "Usage: devdash comment <bead-id> --body=\"...\"" >&2
    exit "$DD_EXIT_USER"
  fi

  local body
  body=$(jq -n --arg pid "$pid" --arg content "$body_text" '{projectId: $pid, content: $content}')
  dd_api POST "/beads/${uuid}/comments" -d "$body" > /dev/null
  echo "Comment added to ${uuid}"
}

dd_comments() {
  local bead_id="${1:-}"
  if [ -z "$bead_id" ]; then
    echo "Usage: devdash comments <bead-id>" >&2
    exit "$DD_EXIT_USER"
  fi
  local pid
  pid=$(dd_project_id)
  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  local result
  result=$(dd_api GET "/beads/${uuid}/comments?projectId=${pid}")

  echo "$result" | jq -r '.data[] | "[\(.createdAt)] \(.authorType)\(if .author.displayName then " (\(.author.displayName))" else "" end):\n  \(.content)\n"'
}

dd_activity() {
  local bead_id="${1:-}"
  local pid
  pid=$(dd_project_id)
  local limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit=*) limit="${1#--limit=}" ;;
      *) bead_id="$1" ;;
    esac
    shift
  done

  local url="/projects/${pid}/activity?limit=${limit}"

  if [ -n "$bead_id" ]; then
    local uuid
    uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1
    url="${url}&targetId=${uuid}"
  fi

  local result
  result=$(dd_api GET "$url")

  echo "$result" | jq -r '.data[] | "[\(.createdAt)] \(.action) by \(.actorType)\(if .actor.displayName then " (\(.actor.displayName))" else "" end)\(if .artifactName then " — \(.artifactName)" else "" end)\(if .metadata then " " + (.metadata | tostring) else "" end)"'
}

dd_stats() {
  local pid
  pid=$(dd_project_id)
  local beads
  beads=$(dd_fetch_beads "$pid")

  local total pending in_progress completed blocked ready
  total=$(echo "$beads" | jq 'length')
  pending=$(echo "$beads" | jq '[.[] | select(.status == "pending")] | length')
  in_progress=$(echo "$beads" | jq '[.[] | select(.status == "in_progress")] | length')
  completed=$(echo "$beads" | jq '[.[] | select(.status == "completed")] | length')
  blocked=$(echo "$beads" | jq '
    ([.[] | select(.status == "completed") | .id]) as $done |
    [.[] | select(.status == "pending" and (.blockedBy | length) > 0)
         | select([.blockedBy[] | IN($done[])] | all | not)]
    | length')
  ready=$(echo "$beads" | jq '
    ([.[] | select(.status == "completed") | .id]) as $done |
    [.[] | select(.status == "pending")
         | select((.blockedBy | length) == 0 or ([.blockedBy[] | IN($done[])] | all))]
    | length')

  echo "Total:       ${total}"
  echo "Pending:     ${pending}"
  echo "In Progress: ${in_progress}"
  echo "Completed:   ${completed}"
  echo "Blocked:     ${blocked}"
  echo "Ready:       ${ready}"
}

dd_team() {
  local pid
  pid=$(dd_project_id)

  local result
  result=$(dd_api GET "/projects/${pid}/members?format=compact")

  # Get project name
  local pname
  pname=$(dd_api GET "/projects/${pid}" | jq -r '.name // "unknown"' 2>/dev/null)

  echo "Team (${pname})"

  # Print roster
  echo "$result" | jq -r '.roster[] | "  \(.name)\t@\(.username)\t\(.email)\t\(.role)"' 2>/dev/null | column -t -s $'\t'

  # Print pending invitations
  local pending
  pending=$(echo "$result" | jq -r '.pending[]' 2>/dev/null)
  if [ -n "$pending" ]; then
    while IFS= read -r email; do
      echo "  ${email}  pending"
    done <<< "$pending"
  fi
}

dd_jobs() {
  local pid
  pid=$(dd_project_id)

  # Parse --bead and --tail flags from any position
  local bead_filter="" tail_lines="" args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --bead=*) bead_filter="${1#--bead=}" ;;
      --tail=*) tail_lines="${1#--tail=}" ;;
      *) args+=("$1") ;;
    esac
    shift
  done
  set -- "${args[@]+"${args[@]}"}"

  local subcmd="${1:-list}"

  # Resolve bead filter to UUID if specified
  local bead_uuid=""
  if [ -n "$bead_filter" ]; then
    bead_uuid=$(dd_resolve_id "$bead_filter" "$pid") || exit 1
  fi

  case "$subcmd" in
    list)
      local jobs
      jobs=$(dd_fetch_jobs "$pid")
      if [ -n "$bead_uuid" ]; then
        jobs=$(echo "$jobs" | jq --arg bid "$bead_uuid" '[.[] | select(.bead_id == $bid)]')
      fi
      echo "$jobs" | jq -r '.[] | "\(.status | if . == "completed" then "✓" elif . == "failed" then "✗" elif . == "running" then "●" else "○" end) \(.id[0:8]) [\(.status)] \(.prompt[0:70] // "no prompt")... \(.created_at // "")"'
      ;;
    show)
      if [ -z "${2:-}" ]; then
        echo "Usage: devdash jobs show <job-id>" >&2
        exit "$DD_EXIT_USER"
      fi
      local job
      job=$(dd_api GET "/jobs/${2}")
      echo "$job" | jq '{
        id: .id,
        beadId: .bead_id,
        status: .status,
        workerType: .worker_type,
        createdAt: .created_at,
        startedAt: .started_at,
        completedAt: .completed_at,
        error: .error,
        failureAnalysis: .failureAnalysis
      }'
      ;;
    log)
      if [ -z "${2:-}" ]; then
        echo "Usage: devdash jobs log <job-id>" >&2
        exit "$DD_EXIT_USER"
      fi
      local job
      job=$(dd_api GET "/jobs/${2}")
      local log_output
      log_output=$(echo "$job" | jq -r '.output_log // "No log available"')
      if [ -n "$tail_lines" ]; then
        echo "$log_output" | tail -n "$tail_lines"
      else
        echo "$log_output"
      fi
      ;;
    failures)
      local jobs
      jobs=$(dd_fetch_jobs "$pid")
      if [ -n "$bead_uuid" ]; then
        jobs=$(echo "$jobs" | jq --arg bid "$bead_uuid" '[.[] | select(.bead_id == $bid)]')
      fi
      echo "$jobs" | jq -r '[.[] | select(.status == "failed")] | sort_by(.created_at) | reverse | .[:10] | .[] | "✗ \(.id[0:8]) \(.error // "unknown error" | .[0:80])  \(.created_at // "")"'
      ;;
    *)
      echo "Usage: devdash jobs [list|show <id>|log <id>|failures] [--bead=<id>] [--tail=N]" >&2
      exit "$DD_EXIT_USER"
      ;;
  esac
}

dd_analyze() {
  if [ -z "${1:-}" ]; then
    echo "Usage: devdash analyze <bead-id>" >&2
    exit "$DD_EXIT_USER"
  fi

  local pid
  pid=$(dd_project_id)
  local bead_id="$1"
  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  # Fetch the bead to get prompt text
  local bead
  bead=$(dd_api GET "/beads/${uuid}?projectId=${pid}")
  local prompt subject description
  subject=$(echo "$bead" | dd_jq -r '.subject')
  description=$(echo "$bead" | dd_jq -r '.description // empty | select(length > 0)')
  # Always use subject + description for analysis prompt (not preInstructions).
  # The analyzer needs to see the task intent, not stale agent instructions.
  if [ -n "$description" ]; then
    prompt="${subject}

${description}"
  else
    prompt="$subject"
  fi

  echo "Analyzing: ${subject}" >&2
  echo "" >&2

  local body
  body=$(jq -n \
    --arg projectId "$pid" \
    --arg beadId "$uuid" \
    --arg prompt "$prompt" \
    '{projectId: $projectId, beadId: $beadId, prompt: $prompt}')

  # Queue the analysis job (runs in E2B sandbox)
  local queue_result
  queue_result=$(dd_api POST "/jobs/analyze" -d "$body")
  local job_id
  job_id=$(echo "$queue_result" | dd_jq -r '.jobId')

  if [ -z "$job_id" ] || [ "$job_id" = "null" ]; then
    echo "Error: failed to queue analysis job" >&2
    echo "$queue_result" >&2
    exit "$DD_EXIT_API"
  fi

  echo "Analysis job queued: ${job_id:0:8}" >&2
  echo "Waiting for sandbox analysis..." >&2

  # Poll for completion (analysis runs in E2B sandbox, typically 1-3 min)
  local status="" job_data="" elapsed=0
  local max_wait=300  # 5 minutes max
  local poll_interval=5
  while [ "$elapsed" -lt "$max_wait" ]; do
    job_data=$(dd_api GET "/jobs/${job_id}")
    status=$(echo "$job_data" | dd_jq -r '.status')

    case "$status" in
      completed)
        break
        ;;
      failed)
        local error_msg
        error_msg=$(echo "$job_data" | dd_jq -r '.error // "Unknown error"')
        echo "Analysis failed: ${error_msg}" >&2
        exit "$DD_EXIT_API"
        ;;
      queued|running)
        sleep "$poll_interval"
        elapsed=$((elapsed + poll_interval))
        ;;
      *)
        echo "Unexpected job status: ${status}" >&2
        exit "$DD_EXIT_API"
        ;;
    esac
  done

  if [ "$status" != "completed" ]; then
    echo "Analysis timed out after ${max_wait}s (job ${job_id:0:8} still ${status})" >&2
    echo "Check job status: devdash jobs show ${job_id:0:8}" >&2
    exit "$DD_EXIT_API"
  fi

  # Parse the analysis result from the job
  local result
  result=$(echo "$job_data" | dd_jq -r '.result // empty')
  if [ -z "$result" ] || [ "$result" = "null" ]; then
    echo "Analysis completed but no result found" >&2
    exit "$DD_EXIT_API"
  fi

  # Display analysis
  echo "$result" | dd_jq -r '"Complexity:  \(.estimatedComplexity)
Files:       \(.affectedFiles | join(", "))
Modules:     \(.affectedModules | join(", "))
Subdivide:   \(.shouldSubdivide)

## Reasoning
\(.reasoning)

## Agent Instructions
\(.agentInstructions)"'

  # Show if subtasks were created (check bead children)
  local children
  children=$(dd_api GET "/beads?projectId=${pid}&parentId=${uuid}" 2>/dev/null) || true
  if [ -n "$children" ] && [ "$children" != "null" ]; then
    local count
    count=$(echo "$children" | dd_jq -r 'if type == "array" then length else 0 end')
    if [ "$count" -gt 0 ]; then
      echo ""
      echo "## Decomposed into ${count} subtasks:"
      echo "$children" | dd_jq -r '.[] | "  - \(.id[0:8]) \(.subject)"'
    fi
  fi
}

dd_dispatch() {
  if [ -z "${1:-}" ]; then
    echo "Usage: devdash dispatch <bead-id> [--priority=N] [--worker=e2b|docker|railway]" >&2
    exit "$DD_EXIT_USER"
  fi

  local pid
  pid=$(dd_project_id)
  local bead_id="$1"
  shift
  local priority="" worker=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --priority=*) priority="${1#--priority=}" ;;
      --worker=*) worker="${1#--worker=}" ;;
    esac
    shift
  done

  local uuid
  uuid=$(dd_resolve_id "$bead_id" "$pid") || exit 1

  # Fetch the bead to get prompt from preInstructions or description
  local bead
  bead=$(dd_api GET "/beads/${uuid}?projectId=${pid}")
  local prompt subject
  prompt=$(echo "$bead" | dd_jq -r '(.preInstructions // empty), (.description // empty), .subject | select(length > 0)' | head -1)
  subject=$(echo "$bead" | dd_jq -r '.subject')

  local body
  body=$(jq -n \
    --arg projectId "$pid" \
    --arg beadId "$uuid" \
    --arg prompt "$prompt" \
    '{projectId: $projectId, beadId: $beadId, prompt: $prompt}')

  if [ -n "$priority" ]; then
    body=$(echo "$body" | jq --argjson p "$priority" '. + {priority: $p}')
  fi
  if [ -n "$worker" ]; then
    body=$(echo "$body" | jq --arg w "$worker" '. + {workerType: $w}')
  fi

  local result
  result=$(dd_api POST "/jobs" -d "$body")
  local job_id status mode
  job_id=$(echo "$result" | dd_jq -r '.id // .run.id // empty')
  status=$(echo "$result" | dd_jq -r '.status // .run.status // empty')
  mode=$(echo "$result" | dd_jq -r '.dispatchMode // "unknown"')

  if [ -z "$job_id" ]; then
    echo "Dispatch response:" >&2
    echo "$result" | dd_jq '.' >&2
    echo "Error: no job ID in response" >&2
    exit "$DD_EXIT_API"
  fi

  echo "Dispatched: ${subject}"
  echo "  Job:    ${job_id}"
  echo "  Status: ${status}"
  echo "  Mode:   ${mode}"
  echo "  Bead:   ${uuid}"
}

dd_blocked() {
  local pid
  pid=$(dd_project_id)
  local beads
  beads=$(dd_fetch_beads "$pid")

  echo "$beads" | jq -r '
    # Build lookup of completed bead IDs
    ([.[] | select(.status == "completed") | .id]) as $done |
    [.[] | select(.status == "pending" and (.blockedBy | length) > 0)
         | select([.blockedBy[] | IN($done[])] | all | not)]
    | sort_by(.priority)
    | .[]
    | "○ \(.localBeadId // .id) [P\(.priority)] - \(.subject)  blocked by: \(.blockedBy | join(", "))"
  '
}

dd_sync() {
  local pid
  pid=$(dd_project_id)
  echo "Triggering reconcile..."
  local result
  result=$(dd_api POST "/sync/${pid}/sync-all" -d '{}')
  echo "$result" | jq '.'
}

dd_import() {
  local pid
  pid=$(dd_project_id)
  local import_all=false
  local issue_number=""
  local state="open"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) import_all=true ;;
      --state=*) state="${1#--state=}" ;;
      [0-9]*) issue_number="$1" ;;
      *) echo "Usage: devdash import <issue-number> | --all [--state=open|all]" >&2; exit "$DD_EXIT_USER" ;;
    esac
    shift
  done

  if [ "$import_all" = true ]; then
    echo "Importing all ${state} GitHub issues..."
    local body
    body=$(jq -n --arg provider "github" --arg state "$state" '{provider: $provider, state: $state}')
    local result
    result=$(dd_api POST "/sync/${pid}/bulk-import" -d "$body")
    local imported
    imported=$(echo "$result" | dd_jq -r '.imported')
    echo "Imported ${imported} issue(s)."
  elif [ -n "$issue_number" ]; then
    echo "Importing GitHub issue #${issue_number}..."
    local result
    result=$(dd_api POST "/sync/${pid}/issues/${issue_number}/import" -d '{}')
    local bead_id
    bead_id=$(echo "$result" | dd_jq -r '.beadId')
    echo "Imported as bead ${bead_id}"
  else
    echo "Usage: devdash import <issue-number> | --all [--state=open|all]" >&2
    exit "$DD_EXIT_USER"
  fi
}

dd_reconcile_tasks() {
  local pid
  pid=$(dd_project_id)
  local dry_run=true
  local auto_fix=false
  local json_output=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --auto-fix) auto_fix=true; dry_run=false ;;
      --dry-run) dry_run=true ;;
      --json) json_output=true ;;
    esac
    shift
  done

  local body
  body=$(jq -n \
    --arg projectId "$pid" \
    --argjson dryRun "$dry_run" \
    --argjson autoFix "$auto_fix" \
    '{projectId: $projectId, dryRun: $dryRun, autoFix: $autoFix}')

  echo "Auditing backlog..." >&2
  local result
  result=$(dd_api POST "/jobs/reconcile-tasks" -d "$body")

  if [ "$json_output" = true ]; then
    echo "$result" | jq '.'
    return
  fi

  # Display summary
  local total scanned duration
  total=$(echo "$result" | jq '.findings | length')
  scanned=$(echo "$result" | jq '.totalBeadsScanned')
  duration=$(echo "$result" | jq '.durationMs')

  echo ""
  echo "Scanned ${scanned} tasks in ${duration}ms — found ${total} finding(s)"
  echo ""

  if [ "$total" -eq 0 ]; then
    echo "No issues found — backlog looks clean!"
    return
  fi

  # Display summary counts
  echo "$result" | jq -r '"  Dependency issues: \(.summary.dependencyIssues)
  Stale tasks:        \(.summary.stale)
  Redundant tasks:    \(.summary.redundant)
  Likely completed:   \(.summary.likelyCompleted)
  Orphaned tasks:     \(.summary.orphaned)
  Auto-fixable:       \(.summary.autoFixable)"'
  echo ""

  # Group findings by type
  for ftype in dependency_issue stale redundant likely_completed orphaned superseded; do
    local count
    count=$(echo "$result" | jq --arg t "$ftype" '[.findings[] | select(.type == $t)] | length')
    if [ "$count" -eq 0 ]; then continue; fi

    local label
    case "$ftype" in
      dependency_issue) label="Dependency Issues" ;;
      stale) label="Stale Tasks" ;;
      redundant) label="Redundant Tasks" ;;
      likely_completed) label="Likely Completed" ;;
      orphaned) label="Orphaned Tasks" ;;
      superseded) label="Superseded Tasks" ;;
    esac

    echo "── ${label} (${count}) ──"
    echo "$result" | jq -r --arg t "$ftype" '.findings[] | select(.type == $t) | "  [\(.severity)] \(.beadSubject)\n    → \(.reason)\(if .relatedBeadId then "\n    related: \(.relatedBeadId[0:8])..." else "" end)"'
    echo ""
  done

  if [ "$auto_fix" = true ]; then
    local fixed
    fixed=$(echo "$result" | jq '.summary.autoFixable')
    echo "Applied ${fixed} auto-fix(es)"
  elif [ "$(echo "$result" | jq '.summary.autoFixable')" -gt 0 ]; then
    echo "Run with --auto-fix to fix dependency issues automatically"
  fi
}

dd_project_create() {
  local name="" repo="" description=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name=*) name="${1#--name=}" ;;
      --repo=*) repo="${1#--repo=}" ;;
      --description=*) description="${1#--description=}" ;;
      *) name="$1" ;;
    esac
    shift
  done

  if [ -z "$name" ]; then
    echo "Usage: devdash project create --name=\"...\" [--repo=owner/repo] [--description=\"...\"]" >&2
    exit "$DD_EXIT_USER"
  fi

  local body
  body=$(jq -n \
    --arg name "$name" \
    --arg githubRepo "$repo" \
    --arg description "$description" \
    '{name: $name} + (if $githubRepo != "" then {githubRepo: $githubRepo} else {} end) + (if $description != "" then {description: $description} else {} end)')

  local result
  result=$(dd_api POST "/projects" -d "$body")
  local id
  id=$(echo "$result" | jq -r '.id')
  local pname
  pname=$(echo "$result" | jq -r '.name')
  echo "Created project: ${id} - ${pname}"

  # Auto-write .devdash if in a git repo
  if git rev-parse --is-inside-work-tree &>/dev/null && [ ! -f "$DD_PROJECT_FILE" ]; then
    local api_url
    api_url=$(dd_api_url)
    echo "{\"api_url\": \"${api_url}\", \"project_id\": \"${id}\"}" > "$DD_PROJECT_FILE"
    echo "Linked: .devdash -> ${id}"
  fi
}

dd_project_list() {
  local projects
  projects=$(dd_api GET "/projects" 2>/dev/null) || {
    echo "Failed to fetch projects. Are you logged in? Run: devdash login" >&2
    exit "$DD_EXIT_API"
  }
  echo "$projects" | jq -r '.[] | "\(.id)  \(.name)  (\(.githubRepo // "no repo"))"'
}

dd_project_delete() {
  local force=false
  local project_id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=true ;;
      *) project_id="$1" ;;
    esac
    shift
  done

  if [ -z "$project_id" ]; then
    echo "Usage: devdash project delete <project-id> [--force]" >&2
    exit "$DD_EXIT_USER"
  fi

  # Resolve short prefix to full UUID
  project_id=$(dd_resolve_project_id "$project_id")

  if [ "$force" != true ]; then
    local project pname
    project=$(dd_api GET "/projects/${project_id}")
    pname=$(echo "$project" | dd_jq -r '.name')
    printf "Delete project '%s'? This cannot be undone. [y/N] " "$pname"
    read -r answer </dev/tty 2>/dev/null || answer="n"
    case "$answer" in
      [Yy]|[Yy]es) ;;
      *) echo "Cancelled."; return ;;
    esac
  fi

  dd_api DELETE "/projects/${project_id}" > /dev/null
  echo "Deleted project: ${project_id}"
}

dd_doctor() {
  local ok=true
  echo "devdash doctor — checking prerequisites"
  echo ""
  for cmd in curl jq openssl python3 git; do
    if command -v "$cmd" &>/dev/null; then
      echo "  ✓ $cmd: $(command -v "$cmd")"
    else
      echo "  ✗ $cmd: NOT FOUND"
      ok=false
    fi
  done
  echo ""
  # Check config
  if [ -f "$DD_TOKEN_FILE" ]; then
    echo "  ✓ auth token: ${DD_TOKEN_FILE}"
  else
    echo "  ○ auth token: not found (run 'devdash login')"
  fi
  if [ -f "$DD_PROJECT_FILE" ]; then
    echo "  ✓ project config: ${DD_PROJECT_FILE}"
  else
    echo "  ○ project config: not found (run 'devdash init')"
  fi
  # Check server connectivity + auth
  if [ -f "$DD_TOKEN_FILE" ]; then
    local api_base
    api_base=$(dd_api_url 2>/dev/null) || api_base=""
    if [ -n "$api_base" ]; then
      local token health_code auth_code
      token=$(cat "$DD_TOKEN_FILE")
      health_code=$(curl -s -o /dev/null -w '%{http_code}' "${api_base}/api/health" 2>/dev/null) || health_code="000"
      if [ "$health_code" = "200" ]; then
        echo "  ✓ server: ${api_base} (reachable)"
        auth_code=$(curl -s -o /dev/null -w '%{http_code}' -H "Authorization: Bearer ${token}" "${api_base}/api/projects" 2>/dev/null) || auth_code="000"
        if [ "$auth_code" -ge 200 ] && [ "$auth_code" -lt 300 ]; then
          echo "  ✓ auth: token accepted"
        else
          echo "  ✗ auth: token rejected (HTTP ${auth_code}) — run 'devdash login'"
          ok=false
        fi
      else
        echo "  ✗ server: ${api_base} (HTTP ${health_code})"
        ok=false
      fi
    fi
  fi
  echo ""
  # Check if dd alias exists
  if alias dd 2>/dev/null | grep -q devdash 2>/dev/null; then
    echo "  ✓ dd alias: active"
  elif type dd 2>/dev/null | grep -q devdash 2>/dev/null; then
    echo "  ✓ dd alias: active (via PATH/function)"
  else
    echo "  ○ dd alias: not set (run 'devdash alias-setup' to configure)"
  fi
  echo ""
  $ok && echo "All good!" || echo "Missing dependencies above."
}

dd_maybe_offer_alias() {
  # Skip in non-interactive environments
  [ -t 0 ] || return 0

  local shell_name shell_rc
  shell_name=$(basename "${SHELL:-/bin/bash}")
  case "$shell_name" in
    zsh)  shell_rc="${HOME}/.zshrc" ;;
    bash)
      if [ -f "${HOME}/.bashrc" ]; then shell_rc="${HOME}/.bashrc"
      else shell_rc="${HOME}/.bash_profile"; fi ;;
    fish) shell_rc="${HOME}/.config/fish/config.fish" ;;
    *)    shell_rc="${HOME}/.${shell_name}rc" ;;
  esac

  # Already configured — nothing to do
  if grep -q 'alias dd=devdash' "$shell_rc" 2>/dev/null; then
    return 0
  fi

  echo ""
  echo "Tip: alias 'dd' → 'devdash' for shorter commands?"
  echo "  (shadows /usr/bin/dd — skip if you use that tool)"
  printf "Add alias to ${shell_rc}? [Y/n] "
  read -r answer </dev/tty 2>/dev/null || answer="n"
  answer="${answer:-y}"

  case "$answer" in
    [Yy]|[Yy]es|"")
      echo "" >> "$shell_rc"
      echo "# devdash: alias dd -> devdash" >> "$shell_rc"
      echo "alias dd=devdash" >> "$shell_rc"
      echo "Added! Run 'source ${shell_rc}' or restart your terminal."
      ;;
    *)
      echo "Skipped. Run 'devdash alias-setup' anytime."
      ;;
  esac
}

dd_maybe_offer_agent_setup() {
  local detected=()
  while IFS= read -r a; do
    [ -n "$a" ] && detected+=("$a")
  done < <(dd_detect_agents)

  echo ""
  if [ ${#detected[@]} -gt 0 ]; then
    echo "AI agent config detected: ${detected[*]}"
  fi

  if [ -t 0 ]; then
    printf "Set up AI agent instructions for devdash? [Y/n] "
    read -r answer </dev/tty 2>/dev/null || answer="n"
    answer="${answer:-y}"
    case "$answer" in
      [Yy]|[Yy]es|"")
        echo ""
        dd_agent_setup
        ;;
      *)
        echo "Skipped. Run 'devdash agent-setup' anytime."
        ;;
    esac
  else
    echo "  Run 'devdash agent-setup' to configure your AI coding agent."
  fi
}

dd_alias_setup() {
  local shell_name shell_rc

  # Detect shell
  shell_name=$(basename "${SHELL:-/bin/bash}")
  case "$shell_name" in
    zsh)  shell_rc="${HOME}/.zshrc" ;;
    bash)
      if [ -f "${HOME}/.bashrc" ]; then
        shell_rc="${HOME}/.bashrc"
      else
        shell_rc="${HOME}/.bash_profile"
      fi
      ;;
    fish) shell_rc="${HOME}/.config/fish/config.fish" ;;
    *)    shell_rc="${HOME}/.${shell_name}rc" ;;
  esac

  echo "This will add 'alias dd=devdash' to ${shell_rc}"
  echo ""
  echo "  Note: this shadows /usr/bin/dd (Unix disk copy utility)."
  echo "  Only do this if you don't use that tool."
  echo ""

  # Check if already set
  if grep -q 'alias dd=devdash' "$shell_rc" 2>/dev/null; then
    echo "Alias already exists in ${shell_rc} — nothing to do."
    return
  fi

  printf "Add alias? [Y/n] "
  read -r answer </dev/tty 2>/dev/null || answer="y"
  answer="${answer:-y}"

  case "$answer" in
    [Yy]|[Yy]es|"")
      echo "" >> "$shell_rc"
      echo "# devdash: alias dd -> devdash" >> "$shell_rc"
      echo "alias dd=devdash" >> "$shell_rc"
      echo ""
      echo "Added to ${shell_rc}. Run 'source ${shell_rc}' or restart your terminal."
      ;;
    *)
      echo "Skipped. You can always run 'devdash alias-setup' later."
      ;;
  esac
}

dd_self_update() {
  local old_version="$DD_VERSION"
  local real_path
  real_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")

  # Detect install method from binary path
  if [[ "$real_path" == *"/node_modules/"* ]]; then
    # npm global install
    echo "Detected npm install. Updating..."
    npm install -g @devdashproject/devdash-cli@latest
  elif [[ "$real_path" == /opt/homebrew/* ]] || [[ "$real_path" == /usr/local/Cellar/* ]]; then
    # Homebrew install
    echo "Detected Homebrew install. Updating..."
    brew upgrade devdash
  elif git -C "$(dirname "$real_path")" rev-parse --is-inside-work-tree &>/dev/null; then
    # Git clone / local dev — can't auto-update, but still refresh agent configs below
    local repo_root
    repo_root=$(git -C "$(dirname "$real_path")" rev-parse --show-toplevel 2>/dev/null)
    echo "Detected git clone at ${repo_root}."
    echo "Run 'git -C \"${repo_root}\" pull' to update the binary."
    old_version=""  # skip version comparison
  else
    # Direct download — re-download from GitHub with checksum verification
    local install_dir
    install_dir=$(dirname "$real_path")
    echo "Detected standalone install at ${real_path}. Downloading latest..."
    local tmp_file="${real_path}.tmp"
    curl -fsSL "https://raw.githubusercontent.com/jasonmassey/devdash-cli/main/bin/devdash" \
      -o "${tmp_file}" \
      || { echo "Download failed." >&2; rm -f "${tmp_file}"; exit "$DD_EXIT_CONFIG"; }
    # Verify checksum if available
    local expected_checksum
    expected_checksum=$(curl -fsSL "https://raw.githubusercontent.com/jasonmassey/devdash-cli/main/bin/devdash.sha256" 2>/dev/null | awk '{print $1}')
    if [ -n "$expected_checksum" ]; then
      local actual_checksum
      actual_checksum=$(shasum -a 256 "${tmp_file}" | awk '{print $1}')
      if [ "$expected_checksum" != "$actual_checksum" ]; then
        echo "Checksum verification failed! Expected ${expected_checksum}, got ${actual_checksum}" >&2
        rm -f "${tmp_file}"
        exit "$DD_EXIT_CONFIG"
      fi
      echo "Checksum verified."
    fi
    mv "${tmp_file}" "${real_path}"
    chmod +x "${real_path}"
  fi

  # Compare versions (skip for git clone — binary wasn't updated)
  if [ -n "$old_version" ]; then
    local new_version
    new_version=$("$real_path" --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo "unknown")
    if [ "$new_version" = "$old_version" ]; then
      echo "Already up to date (v${old_version})."
    else
      echo "Updated v${old_version} → v${new_version}."
    fi
  fi

  # Offer to refresh agent configs if any are installed
  if ! git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    return 0
  fi

  local configured=()
  local agent_files="CLAUDE.md:claude AGENTS.md:codex .cursor/rules/devdash.mdc:cursor .github/copilot-instructions.md:copilot .windsurfrules:windsurf .clinerules:cline"
  for entry in $agent_files; do
    local f="${entry%%:*}" a="${entry#*:}"
    if [ -f "$f" ] && grep -qF "$DD_AGENT_MARKER" "$f" 2>/dev/null; then
      configured+=("$a")
    fi
  done

  if [ ${#configured[@]} -eq 0 ]; then
    return 0
  fi

  echo ""
  echo "Agent configs found: ${configured[*]}"
  if [ -t 0 ]; then
    printf "Refresh agent instructions? [Y/n] "
    read -r answer </dev/tty 2>/dev/null || answer="n"
    answer="${answer:-y}"
    case "$answer" in
      [Yy]|[Yy]es|"")
        dd_agent_setup --agent="$(IFS=','; echo "${configured[*]}")" --force
        ;;
      *)
        echo "Skipped. Run 'devdash agent-setup --force' anytime."
        ;;
    esac
  else
    echo "  Run 'devdash agent-setup --force' to refresh agent instructions."
  fi
}

dd_uninstall() {
  local dry_run=false force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true ;;
      --force)   force=true ;;
      *) echo "Usage: devdash uninstall [--dry-run] [--force]" >&2; exit "$DD_EXIT_USER" ;;
    esac
    shift
  done

  echo "devdash uninstall"
  echo ""

  # ── 1. Detect what was installed ──────────────────────────────
  local items=()

  # Shell alias
  local shell_name shell_rc=""
  shell_name=$(basename "${SHELL:-/bin/bash}")
  case "$shell_name" in
    zsh)  shell_rc="${HOME}/.zshrc" ;;
    bash)
      if [ -f "${HOME}/.bashrc" ]; then shell_rc="${HOME}/.bashrc"
      else shell_rc="${HOME}/.bash_profile"; fi ;;
    fish) shell_rc="${HOME}/.config/fish/config.fish" ;;
    *)    shell_rc="${HOME}/.${shell_name}rc" ;;
  esac
  if [ -n "$shell_rc" ] && grep -q 'alias dd=devdash' "$shell_rc" 2>/dev/null; then
    items+=("alias:${shell_rc}")
  fi

  # Agent instructions (in current repo)
  local agent_files=("CLAUDE.md" "AGENTS.md" ".cursor/rules/devdash.mdc"
                     ".github/copilot-instructions.md" ".windsurfrules" ".clinerules")
  for f in "${agent_files[@]}"; do
    if [ -f "$f" ] && grep -qF "$DD_AGENT_MARKER" "$f" 2>/dev/null; then
      items+=("agent:${f}")
    fi
  done

  # Project file
  if [ -f "$DD_PROJECT_FILE" ]; then
    items+=("project:${DD_PROJECT_FILE}")
  fi

  # Config directory (token, etc.)
  if [ -d "$DD_CONFIG_DIR" ]; then
    items+=("config:${DD_CONFIG_DIR}")
  fi

  # Binary
  local real_path install_method=""
  real_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
  if [[ "$real_path" == *"/node_modules/"* ]]; then
    install_method="npm"
    items+=("binary:npm")
  elif [[ "$real_path" == /opt/homebrew/* ]] || [[ "$real_path" == /usr/local/Cellar/* ]]; then
    install_method="brew"
    items+=("binary:brew")
  elif git -C "$(dirname "$real_path")" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    install_method="git"
    items+=("binary:git (${real_path})")
  else
    install_method="standalone"
    items+=("binary:${real_path}")
  fi

  # ── 2. Show what will be removed ──────────────────────────────
  if [ ${#items[@]} -eq 0 ]; then
    echo "Nothing to uninstall."
    return
  fi

  echo "The following will be removed:"
  echo ""
  for item in "${items[@]}"; do
    local kind="${item%%:*}"
    local detail="${item#*:}"
    case "$kind" in
      alias)   echo "  • Shell alias: remove 'alias dd=devdash' from ${detail}" ;;
      agent)
        # For standalone files (cursor), the whole file is ours
        if [ "$detail" = ".cursor/rules/devdash.mdc" ]; then
          echo "  • Agent config: delete ${detail}"
        else
          echo "  • Agent config: remove devdash block from ${detail}"
        fi
        ;;
      project) echo "  • Project file: delete ${detail}" ;;
      config)  echo "  • Config dir: delete ${detail}/" ;;
      binary)
        case "$install_method" in
          npm)        echo "  • Binary: npm uninstall -g @devdashproject/devdash-cli" ;;
          brew)       echo "  • Binary: brew uninstall devdash" ;;
          git)        echo "  • Binary: skipped (git clone at ${real_path} — remove manually)" ;;
          standalone) echo "  • Binary: delete ${detail}" ;;
        esac
        ;;
    esac
  done
  echo ""

  if [ "$dry_run" = true ]; then
    echo "(dry run — no changes made)"
    return
  fi

  # ── 3. Confirm ────────────────────────────────────────────────
  if [ "$force" != true ]; then
    if [ -t 0 ]; then
      printf "Proceed? [y/N] "
      read -r answer </dev/tty 2>/dev/null || answer="n"
    else
      answer="n"
    fi
    case "$answer" in
      [Yy]|[Yy]es) ;;
      *)
        echo "Aborted."
        return
        ;;
    esac
  fi

  # ── 4. Remove items ──────────────────────────────────────────
  echo ""
  for item in "${items[@]}"; do
    local kind="${item%%:*}"
    local detail="${item#*:}"
    case "$kind" in
      alias)
        # Remove the alias line and its comment from the shell rc
        local tmp
        tmp=$(mktemp)
        grep -v -F 'alias dd=devdash' "$detail" | grep -v -F '# devdash: alias dd -> devdash' > "$tmp" || true
        # Trim trailing blank lines we may have left
        local last_line
        last_line=$(awk 'NF{n=NR} END{print n+0}' "$tmp")
        if [ "$last_line" -gt 0 ]; then
          head -n "$last_line" "$tmp" > "$detail"
        fi
        rm -f "$tmp"
        echo "  ✓ Removed alias from ${detail}"
        ;;
      agent)
        if [ "$detail" = ".cursor/rules/devdash.mdc" ]; then
          rm -f "$detail"
          # Remove .cursor/rules/ if now empty
          rmdir ".cursor/rules" 2>/dev/null || true
          echo "  ✓ Deleted ${detail}"
        else
          # Strip the devdash block from append-mode files
          local tmp
          tmp=$(mktemp)
          awk '
            /<!-- devdash:agent-instructions -->/{skip=1; next}
            /<!-- \/devdash:agent-instructions -->/{skip=0; next}
            !skip{print}
          ' "$detail" > "$tmp"
          # Trim trailing blank lines
          local last_line
          last_line=$(awk 'NF{n=NR} END{print n+0}' "$tmp")
          if [ "$last_line" -gt 0 ]; then
            head -n "$last_line" "$tmp" > "$detail"
          else
            # File is now empty — delete it
            rm -f "$detail"
            # Clean up empty parent dirs we may have created
            local pdir
            pdir=$(dirname "$detail")
            while [ "$pdir" != "." ]; do
              rmdir "$pdir" 2>/dev/null || break
              pdir=$(dirname "$pdir")
            done
            echo "  ✓ Deleted ${detail} (empty after removal)"
            rm -f "$tmp"
            continue
          fi
          rm -f "$tmp"
          echo "  ✓ Removed devdash block from ${detail}"
        fi
        ;;
      project)
        rm -f "$detail"
        echo "  ✓ Deleted ${detail}"
        ;;
      config)
        rm -rf "$detail"
        echo "  ✓ Deleted ${detail}/"
        ;;
      binary)
        case "$install_method" in
          npm)
            npm uninstall -g @devdashproject/devdash-cli 2>/dev/null && \
              echo "  ✓ npm uninstall complete" || \
              echo "  ✗ npm uninstall failed — run manually: npm uninstall -g @devdashproject/devdash-cli"
            ;;
          brew)
            brew uninstall devdash 2>/dev/null && \
              echo "  ✓ brew uninstall complete" || \
              echo "  ✗ brew uninstall failed — run manually: brew uninstall devdash"
            ;;
          git)
            echo "  ⊘ Binary is in a git clone — remove it manually: rm -rf $(dirname "$real_path")"
            ;;
          standalone)
            rm -f "$real_path"
            echo "  ✓ Deleted ${real_path}"
            ;;
        esac
        ;;
    esac
  done

  echo ""
  echo "Uninstall complete."
  if [ -n "$shell_rc" ] && [[ " ${items[*]} " == *" alias:"* ]]; then
    echo "Run 'source ${shell_rc}' or restart your terminal to clear the alias."
  fi
}

dd_prime() {
  # Detect preferred command name
  local dd_cmd
  dd_cmd=$(dd_cmd_name)

  # Read close gate setting
  local close_gate
  close_gate=$(dd_close_gate)

  # Read project ID and frontend URL for PR guidance
  local project_id=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    project_id=$(jq -r '.project_id // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  local frontend_url
  frontend_url=$(dd_frontend_url)

  # Gather project context if available
  local project_header=""
  if [ -f "$DD_PROJECT_FILE" ] && [ -f "$DD_TOKEN_FILE" ]; then
    local pid
    pid=$(jq -r '.project_id // empty' "$DD_PROJECT_FILE" 2>/dev/null)
    if [ -n "$pid" ]; then
      local project_info
      project_info=$(dd_api GET "/projects/${pid}" 2>/dev/null) || true
      if [ -n "$project_info" ]; then
        local pname prepo
        pname=$(echo "$project_info" | jq -r '.name // "unknown"' 2>/dev/null)
        prepo=$(echo "$project_info" | jq -r '.githubRepo // empty' 2>/dev/null)
        project_header="**Project**: ${pname}"
        if [ -n "$prepo" ]; then
          project_header="${project_header} (${prepo})"
        fi
        project_header="${project_header}  |  **ID**: \`${pid:0:8}\`"
      fi

      local beads
      beads=$(dd_fetch_beads "$pid" 2>/dev/null) || true
      if [ -n "$beads" ]; then
        local open ip blocked
        open=$(echo "$beads" | jq '[.[] | select(.status != "completed")] | length' 2>/dev/null)
        ip=$(echo "$beads" | jq '[.[] | select(.status == "in_progress")] | length' 2>/dev/null)
        blocked=$(echo "$beads" | jq '
          ([.[] | select(.status == "completed") | .id]) as $done |
          [.[] | select(.status == "pending" and (.blockedBy | length) > 0)
               | select([.blockedBy[] | IN($done[])] | all | not)]
          | length' 2>/dev/null)
        project_header="${project_header}
**Health**: ${open:-0} open, ${ip:-0} in progress, ${blocked:-0} blocked"
      fi

      # Include repo analysis if available
      local has_analysis
      has_analysis=$(echo "$project_info" | jq -r '.analysis.summary // empty' 2>/dev/null)
      if [ -n "$has_analysis" ]; then
        local a_summary a_type a_complexity a_stack
        a_summary=$(echo "$project_info" | jq -r '.analysis.summary' 2>/dev/null)
        a_type=$(echo "$project_info" | jq -r '.analysis.projectType // "unknown"' 2>/dev/null)
        a_complexity=$(echo "$project_info" | jq -r '.analysis.complexity // "unknown"' 2>/dev/null)
        a_stack=$(echo "$project_info" | jq -r '.analysis.techStack // [] | join(", ")' 2>/dev/null)
        project_header="${project_header}

## Repo Analysis
${a_summary}
- **Type**: ${a_type} | **Complexity**: ${a_complexity}
- **Stack**: ${a_stack}"
      fi
    fi

    # Fetch team roster for this project
    if [ -n "$pid" ]; then
      local roster_json
      roster_json=$(dd_api GET "/projects/${pid}/members?format=compact" 2>/dev/null) || true
      if [ -n "$roster_json" ]; then
        local roster_count pending_count
        roster_count=$(echo "$roster_json" | jq '.roster | length' 2>/dev/null)
        pending_count=$(echo "$roster_json" | jq '.pending | length' 2>/dev/null)
        local total_members=$(( ${roster_count:-0} + ${pending_count:-0} ))
        local roster_rows=""
        roster_rows=$(echo "$roster_json" | jq -r '.roster[:20][] | "| \(.name) | \(.username) | \(.email) | \(.role) |"' 2>/dev/null)
        local pending_slots=$(( 20 - ${roster_count:-0} ))
        local pending_rows=""
        if [ "$pending_slots" -gt 0 ]; then
          pending_rows=$(echo "$roster_json" | jq -r ".pending[:${pending_slots}][] | \"| (pending) | — | \(.) | invited |\"" 2>/dev/null)
        fi
        if [ -n "$roster_rows" ] || [ -n "$pending_rows" ]; then
          local truncation_note=""
          if [ "$total_members" -gt 20 ]; then
            truncation_note="
*Showing 20 of ${total_members} members. Run \`${dd_cmd} team\` for full roster.*"
          fi
          project_header="${project_header}

## Team

| Name | Username | Email | Role |
|------|----------|-------|------|
${roster_rows}${pending_rows:+
${pending_rows}}${truncation_note}

Assign with: \`${dd_cmd} update <id> --owner=<email-or-name>\`"
        fi
      fi
    fi

    # Fetch all projects for cross-repo reference table
    local all_projects
    all_projects=$(dd_api GET "/projects" 2>/dev/null) || true
    if [ -n "$all_projects" ] && echo "$all_projects" | jq -e 'type == "array" and length > 0' >/dev/null 2>&1; then
      local projects_table
      projects_table=$(echo "$all_projects" | jq -r '
        .[] | [
          .id[:8],
          .id,
          .name,
          (if .githubRepo and .githubRepo != "" then "(\(.githubRepo))" else "(no repo)" end)
        ] | @tsv
      ' 2>/dev/null)
      if [ -n "$projects_table" ]; then
        local table_rows=""
        while IFS=$'\t' read -r short full name repo; do
          table_rows="${table_rows}
| \`${short}\` | \`${full}\` | ${name} | ${repo} |"
        done <<< "$projects_table"
        project_header="${project_header}

## All Projects

| Short | Full UUID | Name | Repo |
|-------|-----------|------|------|${table_rows}

Use \`DD_PROJECT_ID=<full-uuid> ${dd_cmd} <command>\` to target a specific project."
      fi
    fi
  fi

  cat <<PRIME
# Dev-Dash Workflow Context

> **Context Recovery**: Run \`devdash prime\` after compaction, clear, or new session.
> Use \`${dd_cmd}\` (dev-dash CLI) for ALL task tracking — never \`bd\`.
$([ -n "$project_header" ] && echo "" && echo "$project_header")

## Rules (MANDATORY)
- **Issue-first**: Create a ${dd_cmd} issue BEFORE writing code. No exceptions.
- **Issue-per-commit**: Every git commit must map to a ${dd_cmd} issue. If scope expands, create new issues.
- **Mark in-progress**: \`${dd_cmd} update <id> --status=in_progress\` before starting work.
- **Pre-commit checkpoint**: Before each \`git commit\`, verify you have an issue. If not, create one.
$(if [ "$close_gate" = "commit" ]; then
    echo "- **Close after commit**: Only close issues after \`git commit\` succeeds."
  else
    echo "- **Close after push**: Only close issues after \`git push\` succeeds — never before."
  fi)
- **No orphaned work**: At session end, every commit must map to a closed issue.
- **Path**: \`$(command -v devdash 2>/dev/null || echo "devdash")\`
- **Preserve stderr**: Avoid \`2>/dev/null\` on ${dd_cmd} commands — stderr contains error details you'll need for debugging failures.
- **Prohibited**: Do NOT use \`bd\`, TodoWrite, TaskCreate, or markdown files for task tracking

## Quick Reference
- **Start**: \`${dd_cmd} ready\` → \`${dd_cmd} show <id>\` → \`${dd_cmd} update <id> --status=in_progress\`
- **Complete**: $(if [ "$close_gate" = "commit" ]; then echo "git add → commit → \`${dd_cmd} close <id> --summary=\"...\" --commit=\$(git rev-parse HEAD)\`"; else echo "git add → commit → push → \`${dd_cmd} close <id> --summary=\"...\" --commit=\$(git rev-parse HEAD)\`"; fi)
- **Report**: \`${dd_cmd} report <id> --status=code_complete|committed|pushed|error --summary="..."\`
- Close summaries are institutional memory — include what, why, decisions, surprises, follow-ups.
- One issue per commit. Scope creep = new issue. Multi-step = parent + children.

## On-Demand Reference
Run these when you need detailed guidance:
- \`${dd_cmd} help cli\` — Full command reference (flags, ID formats, --since syntax)
- \`${dd_cmd} help workflow\` — When to create issues, decomposition patterns, bead relationships
- \`${dd_cmd} help close\` — Close summary expectations with examples
- \`${dd_cmd} help pr\` — PR footer format and multi-issue PRs
- \`${dd_cmd} help projects\` — Cross-project dependencies and multi-repo work
- \`${dd_cmd} help report\` — Progress reporting cadence and status values
PRIME
}

# ── Agent Setup ──────────────────────────────────────────────────

DD_AGENT_MARKER="<!-- devdash:agent-instructions -->"

dd_generate_agent_instructions() {
  local close_gate
  close_gate=$(dd_close_gate)

  # Read project ID and frontend URL for PR guidance
  local project_id=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    project_id=$(jq -r '.project_id // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  local frontend_url
  frontend_url=$(dd_frontend_url)

  local close_rule completing_work
  if [ "$close_gate" = "commit" ]; then
    close_rule='- **Close after commit**: Only close issues after `git commit` succeeds.'
    completing_work='`git add` → `git commit` → `devdash close <id>`'
  else
    close_rule='- **Close after push**: Only close issues after `git push` succeeds — never before.'
    completing_work='`git add` → `git commit` → `git push` → `devdash close <id>`'
  fi

  cat <<INSTRUCTIONS
<!-- devdash:agent-instructions -->

# DevDash — AI Agent Task Tracking

This project uses **devdash** (\`dd\`) for task tracking. DevDash is a shared memory
between you and the user — a place where ideas, decisions, and progress are captured so
nothing gets lost.

Run devdash commands yourself via the terminal — do not just tell the user to run them.
Do NOT use TodoWrite, TaskCreate, \`bd\`, or markdown files for tracking. When the user
says "dd", they mean the devdash CLI, not the Unix \`dd\` data-copy utility.

Issues are called "beads" internally. You'll see this in fields like \`parentBeadId\`.

## Core Principles

**Be a capture reflex.**
When the user mentions a bug, idea, TODO, or "we should probably..." — offer to create
an issue. Don't wait to be asked.

**Issue-first.**
Create an issue before doing work. Your first action when asked to implement something
should be \`devdash create\`.

**One issue per logical unit of work.**
If a task has multiple steps, create a parent issue and child issues. Scope creep during
a task = new issue, not an expanded current one. Every git commit must map to a devdash
issue.

## Rules

1. Create an issue before starting work. No exceptions.
2. \`devdash update <id> --status=in_progress\` before starting work on an issue.
3. Close with a substantive summary — write it for a future reader with zero context.
4. Don't batch unrelated work into a single issue.
${close_rule}
6. No orphaned work: at session end, every commit must map to a closed issue.
7. Git operations MUST succeed before closing. Never run git and devdash close in parallel.
8. Preserve stderr: avoid \`2>/dev/null\` on devdash commands.

## Completing Work

${completing_work}
On successful completions: \`devdash close <id> --summary="..." --commit=\$(git rev-parse HEAD)\`.
If a PR exists, include \`--pr=URL\` too.
Close summaries are institutional memory — include what, why, decisions, surprises, follow-ups.
One issue per commit. Scope creep = new issue. Multi-step = parent + children.
Report at milestones: \`devdash report <id> --status=code_complete|committed|pushed|error --summary="..."\`

## On-Demand Reference

Run these when you need detailed guidance:
- \`devdash help cli\` — Full command reference (flags, ID formats, --since syntax)
- \`devdash help workflow\` — When to create issues, decomposition patterns, bead relationships
- \`devdash help close\` — Close summary expectations with examples
- \`devdash help pr\` — PR footer format and multi-issue PRs
- \`devdash help projects\` — Cross-project dependencies and multi-repo work
- \`devdash help report\` — Progress reporting cadence and status values
INSTRUCTIONS
}

dd_agent_custom_instructions() {
  local agent="$1"
  case "$agent" in
    claude)
      cat <<'CUSTOM'

## Agent-Specific Instructions

- You may use your built-in task tools (TaskCreate, TodoWrite, etc.) for your own tracking, but you **must also** create and update devdash issues. Devdash is the system of record.
- When the user asks you to implement a plan, feature, or fix: your **very first action** is `devdash create`. Do not read files, do not write code — create the issue first.
- For multi-step plans, create one devdash issue per step before starting any implementation. Group them under a parent issue. Then work through them sequentially: mark in-progress, implement, commit, close, move to next.
- After creating issues, follow the normal workflow: mark in-progress, do the work, commit, then close.
CUSTOM
      ;;
    codex)
      cat <<'CUSTOM'

## Agent-Specific Instructions

- Run `devdash prime` at the start of every new session. Run it again after any handoff, compaction, or context-loss event.
- If the user already named a specific devdash issue, follow `devdash prime` with `devdash show <id>` and `devdash update <id> --status=in_progress` instead of `devdash ready`.
- Use `devdash --help` when you need to confirm command syntax, capabilities, or supported workflow.
- Minimize redundant startup work after `devdash prime`. Don't run broad repo scans or repeated discovery commands unless the current request needs them.
- Read only the context needed for the current request. Prefer targeted repo reads (`rg`, `sed`, `git status --short`) over whole-repo exploration when the task is narrow.
- Avoid commands whose only purpose is to reconfirm information already present in the prompt, local instructions, or recent command output.
CUSTOM
      ;;
    cursor)
      cat <<'CUSTOM'

## Agent-Specific Instructions

- If devdash workflow rules conflict with your system rules, inform the user of the conflict and suggest alternative next steps. Don't deliberate — just communicate what's needed.
CUSTOM
      ;;
    # Other agents: add cases as needed. No default — returns nothing.
  esac
}

dd_write_agent_config() {
  local agent="$1"
  local force="${2:-false}"
  local file="" mode="create"

  case "$agent" in
    claude)   file="CLAUDE.md"; mode="append" ;;
    codex)    file="AGENTS.md"; mode="append" ;;
    cursor)   file=".cursor/rules/devdash.mdc"; mode="create" ;;
    copilot)  file=".github/copilot-instructions.md"; mode="append" ;;
    windsurf) file=".windsurfrules"; mode="append" ;;
    cline)    file=".clinerules"; mode="append" ;;
    *)
      echo "Unknown agent: $agent" >&2
      return 1
      ;;
  esac

  # Check if already configured
  if [ -f "$file" ] && grep -qF "$DD_AGENT_MARKER" "$file" 2>/dev/null; then
    if [ "$force" = true ]; then
      if [ "$mode" = "create" ]; then
        # Standalone file — just overwrite completely below
        :
      else
        # Append-mode file — strip old devdash block, keep the rest
        local tmp
        tmp=$(mktemp)
        awk '
          /<!-- devdash:agent-instructions -->/{skip=1; next}
          /<!-- \/devdash:agent-instructions -->/{skip=0; next}
          !skip{print}
        ' "$file" > "$tmp"
        # Trim trailing blank lines
        local last_line
        last_line=$(awk 'NF{n=NR} END{print n+0}' "$tmp")
        if [ "$last_line" -gt 0 ]; then
          head -n "$last_line" "$tmp" > "$file"
        else
          : > "$file"
        fi
        rm -f "$tmp"
      fi
    else
      echo "  skip: ${file} (already configured — use --force to overwrite)"
      return 0
    fi
  fi

  local instructions
  instructions=$(dd_generate_agent_instructions)

  # Append agent-specific instructions if any exist for this agent
  local custom
  custom=$(dd_agent_custom_instructions "$agent")
  if [ -n "$custom" ]; then
    instructions="${instructions}
${custom}"
  fi

  # Wrap with end marker for clean replacement on --force
  local block
  block="${instructions}
<!-- /devdash:agent-instructions -->"

  # Cursor requires .mdc format with YAML frontmatter
  if [ "$agent" = "cursor" ]; then
    block="---
description: \"DevDash task tracking workflow — mandatory for all code changes\"
alwaysApply: true
---

${block}"
  fi

  # Ensure parent directory exists
  local dir
  dir=$(dirname "$file")
  if [ "$dir" != "." ]; then
    mkdir -p "$dir"
  fi

  if [ "$mode" = "create" ] || [ ! -f "$file" ]; then
    # Write (or overwrite) the whole file
    echo "$block" > "$file"
  else
    # Append to existing file
    {
      echo ""
      echo "$block"
    } >> "$file"
  fi

  echo "  wrote: ${file}"
}

dd_detect_agents() {
  # Print names of agents whose instruction files already exist
  # Only detect based on the specific file we'd write to, not just the parent directory
  [ -d ".claude" ] || [ -f "CLAUDE.md" ] && echo "claude"
  [ -f "AGENTS.md" ] && echo "codex"
  [ -d ".cursor/rules" ] && echo "cursor"
  [ -f ".github/copilot-instructions.md" ] && echo "copilot"
  [ -f ".windsurfrules" ] && echo "windsurf"
  [ -f ".clinerules" ] && echo "cline"
  return 0
}

dd_agent_setup() {
  local agents=() force=false all=false close_on=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent=*) IFS=',' read -ra agents <<< "${1#--agent=}" ;;
      --all)     all=true ;;
      --force)   force=true ;;
      --close-on=*) close_on="${1#--close-on=}" ;;
      *) echo "Usage: devdash agent-setup [--agent=claude,codex,...] [--all] [--force] [--close-on=commit|push]" >&2; exit "$DD_EXIT_USER" ;;
    esac
    shift
  done

  # Validate and persist close gate setting
  if [ -n "$close_on" ]; then
    if [[ "$close_on" != "commit" && "$close_on" != "push" ]]; then
      echo "Error: --close-on must be 'commit' or 'push'" >&2
      return 1
    fi
    if [ -f "$DD_PROJECT_FILE" ]; then
      local tmp
      tmp=$(jq --arg g "$close_on" '.close_gate = $g' "$DD_PROJECT_FILE")
      echo "$tmp" > "$DD_PROJECT_FILE"
    fi
  fi

  local all_agents=(claude codex cursor copilot windsurf cline)

  if [ "$all" = true ]; then
    agents=("${all_agents[@]}")
  fi

  # Interactive mode: no --agent and no --all
  if [ ${#agents[@]} -eq 0 ]; then
    echo "Detecting AI coding agents..."
    echo ""

    local detected=()
    while IFS= read -r a; do
      [ -n "$a" ] && detected+=("$a")
    done < <(dd_detect_agents)

    # Display menu
    local i=1
    for a in "${all_agents[@]}"; do
      local mark=" "
      for d in ${detected[@]+"${detected[@]}"}; do
        if [ "$a" = "$d" ]; then mark="*"; break; fi
      done
      local config_file=""
      case "$a" in
        claude)   config_file="CLAUDE.md" ;;
        codex)    config_file="AGENTS.md" ;;
        cursor)   config_file=".cursor/rules/devdash.md" ;;
        copilot)  config_file=".github/copilot-instructions.md" ;;
        windsurf) config_file=".windsurfrules" ;;
        cline)    config_file=".clinerules" ;;
      esac
      printf "  [%s] %d. %-10s → %s\n" "$mark" "$i" "$a" "$config_file"
      i=$((i + 1))
    done
    echo ""
    echo "  * = existing config detected"
    echo ""

    if [ ${#detected[@]} -gt 0 ]; then
      printf "Install for: [d]etected (%s) / [a]ll / [p]ick numbers? " "$(IFS=','; echo "${detected[*]}")"
    else
      printf "Install for: [a]ll / [p]ick numbers (e.g. 1,3,5)? "
    fi
    local default_choice="a"
    [ ${#detected[@]} -gt 0 ] && default_choice="d"
    read -r choice </dev/tty 2>/dev/null || choice="$default_choice"

    case "$choice" in
      d|D|detected)
        if [ ${#detected[@]} -eq 0 ]; then
          echo "No agents detected. Use 'all' or pick numbers."
          return
        fi
        agents=("${detected[@]}")
        ;;
      a|A|all)
        agents=("${all_agents[@]}")
        ;;
      "")
        if [ ${#detected[@]} -gt 0 ]; then
          agents=("${detected[@]}")
        else
          agents=("${all_agents[@]}")
        fi
        ;;
      p|P|pick)
        printf "Enter numbers (comma-separated, e.g. 1,3,5): "
        read -r nums </dev/tty 2>/dev/null || nums=""
        nums=$(echo "$nums" | tr -cd '0-9, ')
        IFS=',' read -ra picks <<< "$nums"
        for n in ${picks[@]+"${picks[@]}"}; do
          n=$(echo "$n" | tr -d ' ')
          if [ -n "$n" ] && [ "$n" -ge 1 ] 2>/dev/null && [ "$n" -le ${#all_agents[@]} ] 2>/dev/null; then
            agents+=("${all_agents[$((n - 1))]}")
          fi
        done
        ;;
      *)
        # Try interpreting as comma-separated numbers (strip any non-printable chars)
        local clean_choice
        clean_choice=$(echo "$choice" | tr -cd '0-9, ')
        if [ -z "$clean_choice" ]; then
          echo "Invalid input. Run 'devdash agent-setup' to try again."
          return
        fi
        IFS=',' read -ra picks <<< "$clean_choice"
        for n in ${picks[@]+"${picks[@]}"}; do
          n=$(echo "$n" | tr -d ' ')
          if [ -n "$n" ] && [ "$n" -ge 1 ] 2>/dev/null && [ "$n" -le ${#all_agents[@]} ] 2>/dev/null; then
            agents+=("${all_agents[$((n - 1))]}")
          fi
        done
        ;;
    esac
  fi

  if [ ${#agents[@]} -eq 0 ]; then
    echo "No agents selected."
    return
  fi

  echo ""
  echo "Writing devdash instructions..."

  # Write per-agent configs
  for agent in "${agents[@]}"; do
    dd_write_agent_config "$agent" "$force"
  done

  echo ""
  echo "Done! Add the new files to git when ready."
}

dd_token_dispatch() {
  local subcmd="${1:-list}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create)
      local name="${1:-CLI token}"
      local result
      result=$(dd_api POST "/auth/tokens" -d "$(jq -n --arg name "$name" '{name: $name}')")
      local token_val token_prefix token_id
      token_val=$(echo "$result" | dd_jq -r '.token')
      token_prefix=$(echo "$result" | dd_jq -r '.tokenPrefix')
      token_id=$(echo "$result" | dd_jq -r '.id')

      echo ""
      echo "Token created! Copy it now — it won't be shown again."
      echo ""
      echo "  ${token_val}"
      echo ""
      echo "  ID:     ${token_id}"
      echo "  Prefix: ${token_prefix}"
      echo "  Name:   ${name}"
      ;;
    list|ls)
      local tokens
      tokens=$(dd_api GET "/auth/tokens")
      local count
      count=$(echo "$tokens" | dd_jq 'length')
      if [ "$count" -eq 0 ]; then
        echo "No API tokens. Create one with: devdash token create \"my token\""
        return
      fi
      echo "$tokens" | dd_jq -r '.[] | "\(if .revoked_at then "✗" else "✓" end) \(.token_prefix)...  \(.name)  (created \(.created_at // "?"))\(if .revoked_at then "  [revoked]" else "" end)  id:\(.id[0:8])"'
      ;;
    revoke)
      if [ -z "${1:-}" ]; then
        echo "Usage: devdash token revoke <token-id>" >&2
        exit "$DD_EXIT_USER"
      fi
      local token_id
      token_id=$(dd_resolve_token_id "$1") || exit 1
      dd_api DELETE "/auth/tokens/${token_id}" > /dev/null
      echo "Revoked: ${token_id}"
      ;;
    *)
      echo "Usage: devdash token [create \"name\"|list|revoke <id>]" >&2
      exit "$DD_EXIT_USER"
      ;;
  esac
}

dd_admin_reset_user() {
  local user_id="" confirm=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user-id=*) user_id="${1#--user-id=}" ;;
      --confirm) confirm=true ;;
      *) user_id="$1" ;;
    esac
    shift
  done

  if [ -z "$user_id" ]; then
    echo "Usage: devdash admin reset-user <user-id> [--confirm]" >&2
    exit "$DD_EXIT_USER"
  fi

  local admin_secret="${ADMIN_SECRET:-}"
  if [ -z "$admin_secret" ] && [ -f "${DD_CONFIG_DIR}/admin-secret" ]; then
    # Check file permissions — warn if too open
    local perms
    perms=$(stat -f '%Lp' "${DD_CONFIG_DIR}/admin-secret" 2>/dev/null || stat -c '%a' "${DD_CONFIG_DIR}/admin-secret" 2>/dev/null)
    if [ -n "$perms" ] && [ "$perms" != "600" ]; then
      echo "Warning: ${DD_CONFIG_DIR}/admin-secret has permissions $perms (should be 600). Fixing..." >&2
      chmod 600 "${DD_CONFIG_DIR}/admin-secret"
    fi
    admin_secret=$(cat "${DD_CONFIG_DIR}/admin-secret")
  fi
  if [ -z "$admin_secret" ]; then
    echo "Error: ADMIN_SECRET env var not set and ~/.config/dev-dash/admin-secret not found" >&2
    exit "$DD_EXIT_CONFIG"
  fi

  local api_url
  api_url=$(dd_api_url)

  if [ "$confirm" != true ]; then
    echo "This will DELETE all projects, beads, jobs, credentials, and sessions for user: ${user_id}"
    echo "The user account will remain but onboarding_completed will be reset to 0."
    echo ""
    printf "Proceed? [y/N] "
    read -r answer </dev/tty 2>/dev/null || answer="n"
    case "$answer" in
      [Yy]|[Yy]es) ;;
      *) echo "Cancelled."; return ;;
    esac
  fi

  local tmpfile http_code body
  tmpfile=$(mktemp)
  http_code=$(curl -s -o "$tmpfile" -w '%{http_code}' -X POST \
    -H "x-admin-secret: ${admin_secret}" \
    -H "Content-Type: application/json" \
    "${api_url}/api/admin/reset-user/${user_id}" 2>/dev/null) || {
    rm -f "$tmpfile"
    echo "Error: could not connect to ${api_url}" >&2
    exit "$DD_EXIT_API"
  }
  body=$(cat "$tmpfile")
  rm -f "$tmpfile"

  if [ "$http_code" -ge 200 ] && [ "$http_code" -lt 300 ]; then
    echo ""
    echo "User reset successfully!"
    echo ""
    echo "$body" | jq '{
      user: .user,
      projectsReset: .projectsReset,
      deleted: .deleted
    }'
  else
    local msg
    msg=$(echo "$body" | jq -r '.error // .message // empty' 2>/dev/null)
    if [ -n "$msg" ]; then
      echo "API error ($http_code): $msg" >&2
    else
      echo "API error ($http_code): $body" >&2
    fi
    exit "$DD_EXIT_API"
  fi
}

dd_help_cli() {
  local cmd
  cmd=$(dd_cmd_name)
  cat <<TOPIC
# CLI Reference

## Viewing issues
- \`${cmd} ready [--since=X]\` — Pending + unblocked issues sorted by priority. Excludes thoughts. **Start here.**
- \`${cmd} list [--status=pending|in_progress|completed] [--since=X] [--parent=<id>]\` — All issues, optionally filtered by status, time, or parent.
- \`${cmd} blocked\` — Pending issues with unsatisfied dependencies.
- \`${cmd} show <id>\` — Full issue detail: description, dependencies, pre-instructions, parent.
- \`${cmd} find <uuid>\` — Look up a bead by full UUID across all accessible projects. Returns bead with project context.
- \`${cmd} stats\` — Project health: open/closed/blocked counts.
- \`${cmd} comments <id>\` — List comments on an issue.
- \`${cmd} activity [<id>]\` — Activity log for an issue or the whole project.

\`--since\` accepts: \`Nh\` (hours), \`Nd\` (days), \`Nw\` (weeks), or \`YYYY-MM-DD\`. Filters on updatedAt (list/stale) or createdAt (ready).

## Creating & updating
- \`${cmd} create --title="..." --description="..." [--type=task|bug|feature|enhancement] [--priority=0-4] [--parent=<id>] [--due=YYYY-MM-DD] [--estimate=N]\`
- \`${cmd} update <id> [--status=pending|in_progress] [--title="..."] [--description="..."] [--priority=0-4] [--owner=email] [--parent=<id>] [--pre-instructions="..."] [--due=YYYY-MM-DD] [--estimate=N]\`
- \`${cmd} comment <id> --body="..."\` — Add a comment to an issue.
- \`${cmd} close <id> [<id>...] [--pr=URL] [--commit=SHA] [--summary="..."]\` — Mark one or many issues completed, optionally with completion metadata.
- \`${cmd} delete <id> [--force] [--cascade]\`

**\`--description\` is required on create.** A good description explains:
- **What** needs to happen and **why** (not just a file list)
- **Approach** or key decisions being made
- **Scope boundaries** — what's explicitly included/excluded
Bad: \`--description="package.json, tsconfig, all source files"\`
Good: \`--description="Create Express MCP server proxying dev-dash API. OAuth via dev-dash Google auth, 8 tools for issue/project CRUD, StreamableHTTP transport. Excludes deployment."\`

## Reporting & monitoring
- \`${cmd} report <id> --status=code_complete|committed|pushed|error [--summary="..."] [--files-changed=N] [--branch=name] [--commit=sha] [--error="..."]\` — Log agent progress. Fire-and-forget.
- \`${cmd} stale [--since=X]\` — List in-progress issues with no recent activity (stale > 30 min).

## Dependencies
- \`${cmd} dep add <issue> <depends-on>\` — Issue is blocked until depends-on completes.
- \`${cmd} dep remove <issue> <depends-on>\` — Remove a dependency.

## Analysis & execution
- \`${cmd} analyze <bead-id>\` — AI analysis of complexity, affected files, agent instructions.
- \`${cmd} dispatch <bead-id> [--priority=N] [--worker=docker|e2b]\` — Dispatch as an agent job.
- \`${cmd} diagnose <id>\` — Investigate bead: status, job history, failure details.
- \`${cmd} score [<id>]\` — Score complexity/automability (single bead or bulk).

## Jobs
- \`${cmd} jobs [--bead=<id>]\` — List recent jobs (optionally filtered by bead)
- \`${cmd} jobs show <id>\` — Job details + failure analysis
- \`${cmd} jobs log <id> [--tail=N]\` — Job output log (last N lines if specified)
- \`${cmd} jobs failures [--bead=<id>]\` — Recent failed jobs

## Sync & maintenance
- \`${cmd} sync\` — Trigger full reconcile with GitHub.
- \`${cmd} import <num> | --all\` — Import GitHub issue(s) into the project.
- \`${cmd} reconcile-tasks [--dry-run] [--auto-fix]\` — Audit backlog for stale/redundant tasks.

## IDs
Full UUID, UUID prefix (e.g. \`27bf\`), or local ID (\`dev-dash-42\`).

## Priority
0=critical, 1=high, 2=medium (default), 3=low, 4=backlog. Integers only.
TOPIC
}

dd_help_workflow() {
  local cmd
  cmd=$(dd_cmd_name)
  cat <<TOPIC
# Workflow — When to Create Issues

DevDash issues are cheap — err on the side of creating them. The goal is a clear audit trail where every commit maps to an issue.

- **Plans with steps**: When building a plan or breaking down a feature, create **one issue per step** BEFORE writing any code. Use \`--parent=<id>\` to group them under the top-level issue. Plan first, then execute each child issue sequentially.
- **Scope creep**: If you discover extra work mid-task (a bug, a refactor, a missing test), create a new issue rather than expanding the current one.
- **One commit = one issue**: If you're about to make a commit that doesn't map to an existing issue, stop and create one first.
- **Exploratory work**: Even spikes or investigations deserve an issue — it tracks time spent and captures findings in the close summary.
- **Don't batch**: Avoid creating a single "do everything" issue. Granular issues make progress visible and let work be parallelized across agents or worktrees.
- **PRs can bundle**: Multiple child issues and commits can roll into a single PR. Granularity is for the issue+commit trail, not the PR.

## Issue Decomposition

For any multi-step goal, pause before creating issues and decompose it first. Create a parent issue for the overall goal, then one child issue per step using \`--parent=<id>\`. Work through them sequentially. Each child gets its own close summary; close the parent last.

Bad: One issue "Build auth system" → one giant commit → sparse close summary.

Good: Parent "Build auth system" with children:
1. "Design auth schema"
2. "Implement login endpoint"
3. "Implement token refresh"
4. "Add auth middleware"

Each child gets its own commit, report, and close summary. The parent gets closed last with an overall summary.

## Bead Relationships

Issues can have **parents** (\`--parent=<id>\`), **dependencies** (\`dep add\`/\`dep remove\`), and siblings (other children of the same parent).

**Before starting work**, run \`${cmd} show <id>\` and check:
- **parentBeadId**: If set, \`${cmd} show <parent-id>\` to understand the larger goal. Sibling beads (other children of that parent) may contain related context, prior decisions, or work you should build on.
- **blockedBy / blocks**: Understand what this issue depends on and what depends on it — especially useful for ordering work.

**When working in a worktree or isolated context**: You lack conversational history. Always explore the parent bead and its children (\`${cmd} list\` filtered by eye, or \`${cmd} show\` on related IDs) to recover context about the broader effort before diving into implementation.

**When to create relationships**:
- Use \`--parent=<id>\` when breaking a large issue into sub-tasks.
- Use \`dep add\` when one issue must complete before another can start (\`dep remove\` to undo).
- Prefer parent/child for "parts of a whole"; prefer dependencies for "X must happen before Y."

## Creating Dependent Work

\`${cmd} create --title="Feature X" --type=feature\` → \`${cmd} create --title="Tests for X" --type=task\` → \`${cmd} dep add <tests-id> <feature-id>\`
TOPIC
}

dd_help_close() {
  cat <<'TOPIC'
# Close Summaries

Close summaries are institutional memory, not status updates. Write them for someone with no background on the work.

**Include:**
- What was implemented (key files, components, endpoints)
- Important decisions made and why
- Anything surprising discovered during implementation
- Follow-up work needed (reference new issues if created)

**Bad:** `--summary="scaffolded the project"`
**Bad:** `--summary="done"`

**Good:** `--summary="Built MCP server with 8 tools (issue CRUD + project list/stats). Used StreamableHTTP transport with bearer auth. OAuth proxies to dev-dash Google auth via new redirect_url flow. Discovered SDK exports changed — McpServer is in sdk/server/mcp.js not sdk/server/index.js. Follow-up: deploy to Railway (issue xyz)."`

**Good:** `--summary="Refactored the auth flow to use PKCE. Moved token validation to middleware so it runs before route handlers. Discovered the refresh token endpoint was returning 200 on invalid tokens — filed a separate issue for that."`
TOPIC
}

dd_help_pr() {
  local project_id=""
  if [ -f "$DD_PROJECT_FILE" ]; then
    project_id=$(jq -r '.project_id // empty' "$DD_PROJECT_FILE" 2>/dev/null)
  fi
  local frontend_url
  frontend_url=$(dd_frontend_url)
  cat <<TOPIC
# Pull Request Guidance

When opening a PR, include a \`## DevDash\` footer section linking the devdash issue(s):

\`\`\`
## DevDash
Project: \`${project_id:-<project-uuid>}\`
Issues:
- [<issue-id>](${frontend_url}/issue/<issue-id>)
\`\`\`

Replace \`<issue-id>\` with the full UUID of each devdash issue the PR addresses.
If the PR addresses multiple issues, list each on its own line.

Multiple child issues and commits can roll into a single PR. Granularity is for the issue+commit trail, not the PR.
TOPIC
}

dd_help_projects() {
  local cmd
  cmd=$(dd_cmd_name)
  cat <<TOPIC
# Cross-Project Work

## Cross-project dependencies
Dependencies can span projects. Use a full UUID from another project as the blocker:
\`${cmd} dep add <local-issue> <full-uuid-from-other-project>\`

The server validates you have access to both projects. When the blocking bead completes in the other project, your bead auto-unblocks.

## Working across multiple projects
Use \`DD_PROJECT_ID=<full-uuid>\` to target a different project for any command:
\`DD_PROJECT_ID=<uuid> ${cmd} show <id>\`
\`DD_PROJECT_ID=<uuid> ${cmd} list --status=pending\`
\`DD_PROJECT_ID=<uuid> ${cmd} create --title="..." --description="..."\`

## Cascading changes
When cascading changes across projects (e.g. an API change that affects CLI and MCP):
1. Create parent issues in each affected project
2. Use cross-project deps to express "CLI work depends on API work"
3. Work the API project first, then the dependents auto-unblock
4. Each project gets its own commits — don't mix repos in one commit
5. Use \`DD_PROJECT_ID=<uuid>\` to create/close issues in the other project
TOPIC
}

dd_help_report() {
  local cmd
  cmd=$(dd_cmd_name)
  cat <<TOPIC
# Progress Reporting

Report at every milestone, not just at the end. This keeps issues from appearing stale and creates a visible trail of progress.

## How to report
\`${cmd} report <id> --status=code_complete --summary="brief description"\`

**Valid statuses:**
- \`code_complete\` — code written
- \`committed\` — git committed
- \`pushed\` — git pushed
- \`error\` — something went wrong

## After commit
\`${cmd} report <id> --status=committed --commit=\$(git rev-parse HEAD) --summary="brief description"\`

## After push
\`${cmd} report <id> --status=pushed --commit=\$(git rev-parse HEAD) --branch=\$(git branch --show-current) --files-changed=N\`

Report is fire-and-forget — if it fails, nothing breaks. **Always report before exiting.**

## When to report
- After finishing a significant sub-step (e.g. "API client done, moving to OAuth")
- After resolving a blocker
- After each commit
- Before any long-running operation
- Don't wait until everything is done
TOPIC
}

dd_help() {
  # Dispatch to topic if provided
  case "${1:-}" in
    cli)       dd_help_cli; return 0 ;;
    workflow)  dd_help_workflow; return 0 ;;
    close)     dd_help_close; return 0 ;;
    pr)        dd_help_pr; return 0 ;;
    projects)  dd_help_projects; return 0 ;;
    report)    dd_help_report; return 0 ;;
    "") ;;  # fall through to full help
    *) echo "Unknown topic: $1. Topics: cli, workflow, close, pr, projects, report" >&2; return 1 ;;
  esac

  local cmd
  cmd=$(dd_cmd_name)
  local close_gate
  close_gate=$(dd_close_gate)
  local workflow_rule tool_ordering
  if [ "$close_gate" = "commit" ]; then
    workflow_rule="close after git commit succeeds. NEVER close in parallel with git commit."
    tool_ordering="git commit FIRST, then ${cmd} close (sequentially)."
  else
    workflow_rule="close after git push succeeds. NEVER close in parallel with git push."
    tool_ordering="git commit+push FIRST, then ${cmd} close (sequentially)."
  fi
  cat <<HELP
devdash — Dev-Dash CLI

Usage: ${cmd} <command> [args]

Commands:
  login [--no-browser]   Authenticate via browser (stores token locally)
  init                   Link current repo to a dev-dash project
  token create "name"    Create a new API token (dd_ prefix, for DD Red etc.)
  token list             List your API tokens
  token revoke <id>      Revoke an API token
  project create         Create a new project (--name, --repo, --description)
  project list           List all your projects
  project delete <id>    Delete a project (--force to skip confirmation)
  list [--status=X]      List beads (optional status filter)
       [--since=X]       Filter by time: Nh (hours), Nd (days), Nw (weeks), YYYY-MM-DD
       [--parent=<id>]   Filter by parent bead
  ready [--since=X]      Show beads ready to work (no blockers)
  blocked                Show blocked issues with their blockers
  show <id>              Show bead details
  find <uuid>            Look up a bead across all projects (full UUID required)
  create --title="..."   Create a bead (--type, --priority, --description, --parent,
                         --due=YYYY-MM-DD, --estimate=N)
  update <id> --key=val  Update bead fields (--status, --priority, --owner, --title,
                         --description, --pre-instructions, --due, --estimate)
  close <id> [<id>...]   Close one or more beads
                         (--pr=URL, --commit=SHA, --summary="...")
  comment <id> --body="..." Add a comment to a bead
  comments <id>          List comments on a bead
  activity [<id>]        Activity log (per-bead or project-wide)
  stale [--since=X]      List stale in-progress issues (no recent activity)
  report <id>            Submit agent exit report
                         (--status=code_complete|committed|pushed|error,
                          --summary, --files-changed, --branch, --commit, --error)
  delete <id> [--force] [--cascade]
                         Delete a bead (--cascade deletes children too)
  analyze <bead-id>      Analyze a bead: complexity, files, agent instructions
  dispatch <bead-id>     Dispatch a bead as an agent job (--priority, --worker)
  diagnose <id>          Investigate bead: status, job history, failure details
  dep add <id> <dep-id>  Add dependency (id depends on dep-id)
  dep remove <id> <dep-id> Remove a dependency
  jobs [list] [--bead=<id>]
                         List recent jobs (optionally filtered by bead)
  jobs show <id>         Show job details + failure analysis
  jobs log <id> [--tail=N]
                         Show job output log (last N lines if specified)
  jobs failures [--bead=<id>]
                         Show recent failed jobs (optionally filtered by bead)
  reconcile-tasks        Audit backlog for stale/redundant/completed tasks
                         (--dry-run (default), --auto-fix, --json)
  team                   Show project team roster (members + pending invitations)
  stats                  Show project statistics
  sync                   Trigger full reconcile with GitHub
  import <num> | --all   Import GitHub issue(s) into the current project
                         (--all imports all open issues, --state=open|all)
  prime                  Output AI-optimized workflow context (for agent injection)
  agent-setup            Write devdash instructions for AI agents
                         (--agent=claude,codex,... | --all) [--force]
  admin reset-user <id>  Reset user state for onboarding re-testing (--confirm)
  doctor                 Check prerequisites and configuration
  alias-setup            Add 'dd' -> 'devdash' alias to your shell
  uninstall              Remove devdash: alias, agent configs, token, binary
                         (--dry-run to preview, --force to skip confirmation)
  self-update            Update devdash to the latest version
  version                Show version
  help [topic]           Show this help, or a topic: cli, workflow, close, pr, projects, report

Global flags:
  --project=<id>         Override project for this command (UUID or prefix)

ID formats:
  Full UUID              e.g. 27bf66bd-945f-4714-93fd-0c3322b720f4
  Short prefix           e.g. 27bf (any unique prefix works)
  Local ID               e.g. dev-dash-42 (project-scoped shorthand)

────────────────────────────────────────────────────────────────
AGENT REFERENCE — store this section in memory for future sessions
────────────────────────────────────────────────────────────────

Flag values (exact strings the CLI accepts):

  --status=<value>       pending | in_progress | completed
  --since=<value>        Nh (hours) | Nd (days) | Nw (weeks) | YYYY-MM-DD
  --type=<value>         task | bug | feature | enhancement | thought
  --priority=<N>         0 (critical) | 1 (high) | 2 (medium, default) | 3 (low) | 4 (backlog)
  --project=<id>         Full UUID, short prefix, or DD_PROJECT_ID env var

  create flags:          --title="..." --type=task --priority=2 --description="..." --parent=<id>
  update flags:          --status=in_progress --priority=1 --owner=email --title="..."
                         --description="..." --pre-instructions="..."
  close flags:           --pr=URL --commit=SHA --summary="..." (completion metadata)
  delete flags:          --force (skip confirmation) --cascade (delete children)
  dispatch flags:        --priority=N --worker=e2b|docker|railway

Cross-project commands (use --project or DD_PROJECT_ID):

  DD_PROJECT_ID=<uuid> ${cmd} list
  ${cmd} --project=<prefix> show <bead-id>

What to store in agent memory:

  - Project IDs: run '${cmd} project list' and save the ID + name table.
    Use DD_PROJECT_ID=<id> to target a specific project without 'init'.
  - Preferred command: '${cmd}' (or 'devdash'). Use 'dd' if aliased.
  - Workflow rules: always create issue before coding, mark in_progress,
    ${workflow_rule}
  - Priority scale: 0-4 integers, NOT strings like "high"/"medium"/"low".
  - PR footer: include a ## DevDash section with project ID + issue URL(s).
  - Session recovery: run '${cmd} prime' after context loss/compaction.
  - Tool ordering: ${tool_ordering}
    If git fails, a parallel ${cmd} close gets killed.
HELP

  # Append live project list if authenticated
  if [ -f "$DD_TOKEN_FILE" ]; then
    local projects
    projects=$(dd_api GET "/projects" 2>/dev/null) || true
    if [ -n "$projects" ] && [ "$projects" != "[]" ]; then
      echo ""
      echo "Your projects (save these IDs to agent memory):"
      echo ""
      echo "$projects" | jq -r '.[] | "  \(.id[0:8])  \(.id)  \(.name)\(if .githubRepo then "  (\(.githubRepo))" else "" end)"' 2>/dev/null || true
      echo ""
    fi
  fi
}

# ── Main ─────────────────────────────────────────────────────────

# Extract global --project flag before dispatching commands
_args=()
for _arg in "$@"; do
  case "$_arg" in
    --project=*) export DD_PROJECT_ID="${_arg#--project=}" ;;
    *) _args+=("$_arg") ;;
  esac
done
set -- "${_args[@]+"${_args[@]}"}"

case "${1:-help}" in
  login)   shift; dd_login "$@" ;;
  init)    shift; dd_init "$@" ;;
  token)   shift; dd_token_dispatch "$@" ;;
  project)
    shift
    case "${1:-}" in
      create) shift; dd_project_create "$@" ;;
      list)   dd_project_list ;;
      delete) shift; dd_project_delete "$@" ;;
      *) echo "Usage: devdash project [create|list|delete]" >&2; exit "$DD_EXIT_USER" ;;
    esac
    ;;
  list)    shift; dd_list "$@" ;;
  ready)   shift; dd_ready "$@" ;;
  blocked) dd_blocked ;;
  show)    shift; dd_show "$@" ;;
  find)    shift; dd_find "$@" ;;
  create)  shift; dd_create "$@" ;;
  update)  shift; dd_update "$@" ;;
  close)   shift; dd_close "$@" ;;
  stale)   shift; dd_stale "$@" ;;
  report)  shift; dd_report "$@" ;;
  delete)  shift; dd_delete "$@" ;;
  analyze)  shift; dd_analyze "$@" ;;
  dispatch) shift; dd_dispatch "$@" ;;
  comment)  shift; dd_comment "$@" ;;
  comments) shift; dd_comments "$@" ;;
  activity) shift; dd_activity "$@" ;;
  dep)
    shift
    case "${1:-}" in
      add) shift; dd_dep_add "$@" ;;
      remove) shift; dd_dep_remove "$@" ;;
      *) echo "Usage: devdash dep [add|remove] <issue> <depends-on>" >&2; exit "$DD_EXIT_USER" ;;
    esac
    ;;
  score)    shift; dd_score "$@" ;;
  diagnose) shift; dd_diagnose "$@" ;;
  jobs)    shift; dd_jobs "$@" ;;
  reconcile-tasks) shift; dd_reconcile_tasks "$@" ;;
  team)    dd_team ;;
  stats)   dd_stats ;;
  sync)    dd_sync ;;
  import)  shift; dd_import "$@" ;;
  prime)   dd_prime ;;
  admin)
    shift
    case "${1:-}" in
      reset-user) shift; dd_admin_reset_user "$@" ;;
      *) echo "Usage: devdash admin [reset-user]" >&2; exit "$DD_EXIT_USER" ;;
    esac
    ;;
  agent-setup) shift; dd_agent_setup "$@" ;;
  doctor)  dd_doctor ;;
  alias-setup) dd_alias_setup ;;
  uninstall)   shift; dd_uninstall "$@" ;;
  self-update) dd_self_update ;;
  version|--version|-v) dd_version ;;
  help|--help|-h) shift; dd_help "$@" ;;
  *) echo "Unknown command: $1. Run 'devdash help' for usage." >&2; exit "$DD_EXIT_USER" ;;
esac
